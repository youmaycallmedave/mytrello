---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Trello</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-[#1d2125] text-white min-h-screen font-sans antialiased">

  <header class="sticky top-0 z-40 bg-[#1d2125]/95 backdrop-blur border-b border-white/5 h-12 flex items-center px-4 gap-3">
    <button id="btn-home" class="flex items-center gap-2 hover:opacity-70 transition-opacity flex-shrink-0">
      <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4 5a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5zm9 0a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2V5zm0 9a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2v-5zM4 14a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5z"/>
      </svg>
      <span class="font-semibold text-sm">My Trello</span>
    </button>
    <div id="board-tabs" class="flex items-center gap-0.5"></div>
    <div id="header-breadcrumb" class="hidden items-center gap-2 text-sm min-w-0">
      <span class="text-white/30">/</span>
      <span id="header-project-name" class="text-white/70 truncate"></span>
    </div>
    <div id="header-timer" class="hidden items-center gap-2 text-xs bg-red-500/10 border border-red-500/15 px-2.5 py-1 rounded-lg">
      <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse flex-shrink-0"></span>
      <span id="header-timer-task" class="truncate max-w-[110px] text-white/60"></span>
      <span id="header-timer-display" class="font-mono font-medium tabular-nums text-red-300"></span>
      <button id="btn-stop-timer" class="text-red-400/70 hover:text-red-300 transition-colors leading-none ml-0.5">⏹</button>
    </div>
    <div class="ml-auto flex items-center gap-2 flex-shrink-0">
      <button id="btn-crm"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        CRM
      </button>
      <button id="btn-design-gym"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        Дизайн
      </button>
      <button id="btn-journal"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        Дневник
      </button>
      <button id="btn-history"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        История
      </button>
      <button id="btn-backup"
        class="hidden text-white/25 hover:text-white/60 transition-colors p-1.5 rounded-md hover:bg-white/5"
        title="Скачать бэкап">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
      </button>
      <!-- coins hidden -->
      <span id="header-user-email" class="hidden text-xs text-white/30 max-w-[160px] truncate"></span>
      <button id="btn-new-project"
        class="hidden text-xs bg-blue-600 hover:bg-blue-500 transition-colors px-3 py-1.5 rounded-md font-medium">
        + Новый проект
      </button>
      <button id="btn-logout"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        Выйти
      </button>
    </div>
  </header>

  <main id="app"></main>

  <!-- Gamification panel -->
  <div id="gam-overlay" class="hidden fixed inset-0 z-44" style="background:rgba(0,0,0,0.3)"></div>
  <div id="gam-panel" class="fixed right-0 top-12 h-[calc(100vh-3rem)] w-80 bg-[#1e2328] border-l border-white/8 z-45 translate-x-full transition-transform duration-300 overflow-y-auto"></div>

  <div id="modal-overlay" class="hidden fixed inset-0 bg-black/70 z-50 flex items-start justify-center pt-16 px-4">
    <div class="bg-[#282e33] rounded-xl shadow-2xl w-full max-w-md relative">
      <button id="modal-close" class="absolute top-3 right-3 text-white/30 hover:text-white/70 transition-colors text-lg leading-none">✕</button>
      <div id="modal-body"></div>
    </div>
  </div>

  <script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js'

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )

  // ─── CONSTANTS ───────────────────────────────────────────────────────────────
  const DEFAULT_STATUSES = [
    { id: 'todo',       label: 'To Do',        color: '#6b7280' },
    { id: 'inprogress', label: 'In Progress',  color: '#3b82f6' },
    { id: 'pending',    label: 'Wait',         color: '#eab308' },
    { id: 'archived',   label: 'Done',         color: '#22c55e' },
    { id: 'later',      label: 'To Do Later',  color: '#8b5cf6' },
  ]
  function boardStatuses() { return DEFAULT_STATUSES }
  function statusById(id) { return boardStatuses().find(s => s.id === id) || boardStatuses()[0] }
  function smartDefaultTab() {
    const sts = boardStatuses()
    const ps = projects()
    const withProjects = sts.find(s => ps.some(p => (p.status || sts[0].id) === s.id))
    return withProjects?.id || sts[0]?.id
  }

  // ─── STATE ───────────────────────────────────────────────────────────────────
  const STORAGE_KEY = 'my-trello-v2'
  let appData = { boards: [] }
  let currentProjectId = null
  let homeTab = 'inprogress'
  let homeSearch = ''
  let saveTimer = null
  let dbSaveTimer = null
  let currentSession = null
  let dataLoaded = false
  const collapsed = new Set()
  let hideDoneTasks = false
  let hideDoneSubtasks = false
  let activeTimer = null  // { projId, stId, taskId, projTitle, stTitle, taskTitle, startedAt }
  let timerInterval = null
  let pendingScrollTaskId = null
  let savedSelection = null
  let journalYear = new Date().getFullYear()
  let journalMonth = new Date().getMonth() // 0-based

  // ─── UTILS ───────────────────────────────────────────────────────────────────
  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 6)
  }
  function esc(s) {
    return String(s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;')
  }

  function saveSelection() {
    const sel = window.getSelection()
    if (!sel || sel.rangeCount === 0) return null
    return sel.getRangeAt(0).cloneRange()
  }
  function restoreSelection(range) {
    const sel = window.getSelection()
    if (!sel || !range) return
    sel.removeAllRanges()
    sel.addRange(range)
  }
  function sanitizeNoteHTML(html) {
    const tmp = document.createElement('div')
    tmp.innerHTML = html
    function walk(node) {
      if (node.nodeType === 3) return node.textContent.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      if (node.nodeName === 'BR') return '<br>'
      if (node.nodeName === 'A') {
        const href = (node.getAttribute('href') || '').trim()
        if (/^https?:\/\//i.test(href) || /^mailto:/i.test(href)) {
          const inner = Array.from(node.childNodes).map(walk).join('')
          return `<a href="${href.replace(/"/g,'&quot;')}" target="_blank" rel="noopener noreferrer">${inner}</a>`
        }
        return Array.from(node.childNodes).map(walk).join('')
      }
      const isBlock = /^(DIV|P|H[1-6]|LI|BLOCKQUOTE)$/.test(node.nodeName)
      const inner = Array.from(node.childNodes).map(walk).join('')
      return isBlock && inner ? inner + '<br>' : inner
    }
    return Array.from(tmp.childNodes).map(walk).join('').replace(/(<br>\s*)+$/, '')
  }
  function renderNoteContent(content) {
    if (!content) return ''
    if (content.includes('<a ') || content.includes('<br>')) return content
    return content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')
  }

  // ─── STORAGE ─────────────────────────────────────────────────────────────────
  function loadLocal() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (raw) appData = JSON.parse(raw)
    } catch (_) {}
    migrateData()
    if (!projects().length) seedDemo()
  }

  async function loadFromDB() {
    const { data, error } = await sb
      .from('projects_data')
      .select('data')
      .single()
    if (error || !data) {
      loadLocal()
      return
    }
    appData = data.data
    migrateData()
    localStorage.setItem(STORAGE_KEY, JSON.stringify(appData))
  }

  function save() {
    clearTimeout(saveTimer)
    saveTimer = setTimeout(() => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(appData))
    }, 300)
    saveToDB()
  }

  function saveToDB() {
    if (!currentSession) return
    clearTimeout(dbSaveTimer)
    dbSaveTimer = setTimeout(async () => {
      await sb.from('projects_data').upsert(
        { user_id: currentSession.user.id, data: appData, updated_at: new Date().toISOString() },
        { onConflict: 'user_id' }
      )
    }, 1500)
  }

  // ─── DEMO DATA ───────────────────────────────────────────────────────────────
  function seedDemo() {
    appData = {
      boards: [{ id: 'work', name: 'Работа', emoji: '💼', projects: [
        {
          id: uid(), title: 'Собрать сайт', color: 'blue', updatedAt: Date.now(), deadline: null, status: 'inprogress',
          subtasks: [
            {
              id: uid(), title: 'Главная страница',
              tasks: [
                { id: uid(), title: 'Hero секция', done: true },
                { id: uid(), title: 'Навигация', done: true },
                { id: uid(), title: 'Секция с фичами', done: false },
                { id: uid(), title: 'Футер', done: false },
              ]
            },
            {
              id: uid(), title: 'Страница «О нас»',
              tasks: [
                { id: uid(), title: 'Написать текст', done: false },
                { id: uid(), title: 'Добавить фото', done: false },
              ]
            },
            {
              id: uid(), title: 'Деплой',
              tasks: [
                { id: uid(), title: 'GitHub репо', done: true },
                { id: uid(), title: 'Подключить Vercel', done: false },
              ]
            },
          ],
          notes: [
            { id: uid(), title: '🔑 Доступы', content: 'FTP: ftp.example.com\nLogin: admin\nPass: ...' },
            { id: uid(), title: '💬 Клиент', content: 'Иванов Иван\nTelegram: @ivanov\nХочет синий цвет, без анимаций' },
          ]
        },
      ]}],
      activeBoardId: 'work'
    }
  }

  function currentBoard() {
    return appData.boards?.find(b => b.id === appData.activeBoardId) || appData.boards?.[0]
  }
  function projects() { return currentBoard()?.projects || [] }

  function migrateData() {
    if (!appData.boards) {
      appData.boards = [{ id: 'work', name: 'Работа', emoji: '💼', projects: appData.projects || [] }]
      appData.activeBoardId = 'work'
      delete appData.projects
    }
    if (!appData.activeBoardId) appData.activeBoardId = appData.boards[0]?.id
    if (!appData.crm) appData.crm = { clients: [], projects: [] }
    if (!appData.crm.clients) appData.crm.clients = []
    if (!appData.crm.projects) appData.crm.projects = []
    // one-time rename: Работа → Work
    const workBoard = appData.boards?.find(b => b.id === 'work' && b.name === 'Работа')
    if (workBoard) { workBoard.name = 'Work'; workBoard.emoji = '💼' }
    // one-time reset: clear test coins
    if (appData.gamification && !appData.gamification.resetV1) {
      appData.gamification.coins = 0
      appData.gamification.coinLog = []
      appData.gamification.resetV1 = true
    }
    // one-time reset: clear design gym progress + coins (fresh start with toggle)
    if (!appData._resetV2) {
      if (appData.gamification) { appData.gamification.coins = 0; appData.gamification.coinLog = [] }
      appData.designGym = { days: {}, doneIdx: [] }
      appData._resetV2 = true
    }
    // one-time reset: full fresh start before day-1
    if (!appData._resetV3) {
      if (appData.gamification) { appData.gamification.coins = 0; appData.gamification.coinLog = [] }
      appData.designGym = { days: {}, doneIdx: [] }
      appData._resetV3 = true
    }
  }

  function getProject(id) {
    for (const b of (appData.boards || [])) {
      const p = b.projects.find(p => p.id === id)
      if (p) return p
    }
    return null
  }

  function touchProject(id) {
    const p = getProject(id)
    if (p) p.updatedAt = Date.now()
  }

  function saveProject() {
    if (currentProjectId) touchProject(currentProjectId)
    save()
  }

  function elapsedSince(ts) {
    if (!ts) return '—'
    const diff = Math.max(0, Math.floor((Date.now() - ts) / 60000))
    const d = Math.floor(diff / 1440)
    const h = Math.floor((diff % 1440) / 60)
    const m = diff % 60
    if (d > 0) return `${d}д ${h}ч ${m}м`
    if (h > 0) return `${h}ч ${m}м`
    return `${m}м`
  }

  // ─── TIMER ───────────────────────────────────────────────────────────────────
  function fmtDuration(seconds) {
    if (seconds < 60) return `${seconds}с`
    const m = Math.floor(seconds / 60)
    const h = Math.floor(m / 60)
    if (h > 0) return `${h}ч ${m % 60}м`
    return `${m}м`
  }

  function fmtHHMM(date) {
    return `${String(date.getHours()).padStart(2,'0')}:${String(date.getMinutes()).padStart(2,'0')}`
  }

  const ORIGINAL_TITLE = document.title

  function timerFaviconSVG(color) {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><circle cx="16" cy="16" r="16" fill="${color}"/><circle cx="16" cy="17" r="8" fill="none" stroke="white" stroke-width="2"/><line x1="16" y1="9" x2="16" y2="7" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="17" x2="16" y2="12" stroke="white" stroke-width="2.5" stroke-linecap="round"/><line x1="16" y1="17" x2="20" y2="17" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="4" x2="14" y2="6" stroke="white" stroke-width="1.5" stroke-linecap="round"/><line x1="20" y1="4" x2="18" y2="6" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>`
  }

  function setFavicon(active, secs = 0) {
    let link = document.querySelector('link[rel="icon"]')
    if (!link) { link = document.createElement('link'); link.rel = 'icon'; document.head.appendChild(link) }
    link.type = 'image/svg+xml'
    if (!active) { link.href = '/favicon.svg'; return }
    const color = secs < 1800 ? '#22c55e' : secs < 3600 ? '#eab308' : '#ef4444'
    link.href = 'data:image/svg+xml,' + encodeURIComponent(timerFaviconSVG(color))
  }

  function timerColor(secs) {
    return secs < 1800 ? '#22c55e' : secs < 3600 ? '#eab308' : '#ef4444'
  }

  function applyActiveRowStyle(row, secs) {
    const c = timerColor(secs)
    row.style.borderLeft = `3px solid ${c}99`
    row.style.backgroundColor = `${c}12`
    row.style.borderRadius = '0 8px 8px 0'
    row.style.paddingLeft = '6px'
  }

  function clearActiveRowStyle(row) {
    row.style.borderLeft = ''
    row.style.backgroundColor = ''
    row.style.borderRadius = ''
    row.style.paddingLeft = ''
  }

  function startTimerTick() {
    clearInterval(timerInterval)
    timerInterval = setInterval(() => {
      if (!activeTimer) { clearInterval(timerInterval); timerInterval = null; return }
      const secs = Math.floor((Date.now() - activeTimer.startedAt) / 1000)
      const el = document.getElementById('header-timer-display')
      if (el) el.textContent = fmtDuration(secs)
      document.title = `▶ ${activeTimer.projTitle} › ${activeTimer.stTitle} › ${activeTimer.taskTitle} — ${fmtDuration(secs)}`
      setFavicon(true, secs)
      // update active row color + dot color
      const row = document.querySelector('[data-active-task-row]')
      if (row) {
        applyActiveRowStyle(row, secs)
        const dot = row.querySelector('[data-timer-dot]')
        if (dot) dot.style.background = timerColor(secs)
      }
    }, 1000)
  }

  function updateTimerButtons() {
    const secs = activeTimer ? Math.floor((Date.now() - activeTimer.startedAt) / 1000) : 0
    document.querySelectorAll('[data-timer-task-id]').forEach(btn => {
      const isActive = activeTimer &&
        btn.dataset.timerTaskId === activeTimer.taskId &&
        btn.dataset.timerStId === activeTimer.stId
      const row = btn.closest('[data-drag-task]')
      if (isActive) {
        const c = timerColor(secs)
        btn.innerHTML = `<span style="display:flex;align-items:center;gap:4px"><span data-timer-dot style="width:7px;height:7px;border-radius:50%;background:${c};animation:pulse 1.5s ease-in-out infinite"></span><svg width="9" height="9" viewBox="0 0 9 9" fill="currentColor"><rect x="1" y="1" width="7" height="7" rx="1.5"/></svg></span>`
        btn.className = 'flex-shrink-0 px-1.5 py-1.5 transition-all text-xs text-white/70 opacity-100'
        if (row) { row.setAttribute('data-active-task-row', ''); applyActiveRowStyle(row, secs) }
      } else {
        btn.innerHTML = '▶'
        btn.className = 'flex-shrink-0 px-1.5 py-1.5 transition-all text-xs text-white/20 hover:text-green-400 opacity-0 group-hover/task:opacity-100'
        if (row) { row.removeAttribute('data-active-task-row'); clearActiveRowStyle(row) }
      }
    })
    updateHeaderTimer()
  }

  function updateHeaderTimer() {
    const hdr = document.getElementById('header-timer')
    if (!hdr) return
    if (activeTimer) {
      hdr.classList.remove('hidden')
      hdr.classList.add('flex')
      const taskEl = document.getElementById('header-timer-task')
      if (taskEl) taskEl.textContent = activeTimer.taskTitle
      const dispEl = document.getElementById('header-timer-display')
      if (dispEl) dispEl.textContent = fmtDuration(Math.floor((Date.now() - activeTimer.startedAt) / 1000))
    } else {
      hdr.classList.add('hidden')
      hdr.classList.remove('flex')
    }
  }

  // ─── BACKUP ──────────────────────────────────────────────────────────────────
  const BACKUP_KEY = 'lastBackupAt'
  const BACKUP_INTERVAL = 7 * 24 * 60 * 60 * 1000 // 7 days

  function daysSinceBackup() {
    const last = parseInt(localStorage.getItem(BACKUP_KEY) || '0')
    return Math.floor((Date.now() - last) / 86400000)
  }

  async function downloadBackup() {
    const btn = document.getElementById('btn-backup')
    if (btn) { btn.style.opacity = '0.4'; btn.style.pointerEvents = 'none' }

    let timeEntries = []
    if (currentSession) {
      const { data } = await sb.from('time_entries').select('*').eq('user_id', currentSession.user.id)
      if (data) timeEntries = data
    }

    const backup = {
      version: 1,
      exportedAt: new Date().toISOString(),
      appData,
      timeEntries
    }

    const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = `mytrello-backup-${new Date().toISOString().slice(0,10)}.json`
    document.body.appendChild(a); a.click(); document.body.removeChild(a)
    URL.revokeObjectURL(url)

    localStorage.setItem(BACKUP_KEY, Date.now().toString())
    if (btn) { btn.style.opacity = ''; btn.style.pointerEvents = '' }
    document.getElementById('backup-banner')?.remove()
  }

  function backupBannerHTML() {
    const days = daysSinceBackup()
    if (days < 7) return ''
    const msg = days === 0 ? 'Ты ещё не делал бэкап' : `Последний бэкап ${days} дн назад`
    return `
      <div id="backup-banner" class="mb-5 flex items-center gap-3 bg-yellow-500/8 border border-yellow-500/20 rounded-xl px-4 py-3">
        <svg class="w-4 h-4 text-yellow-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <span class="text-sm text-white/60 flex-1">${msg}</span>
        <button data-action="download-backup"
          class="text-xs bg-yellow-500/15 hover:bg-yellow-500/25 text-yellow-300 px-3 py-1.5 rounded-lg transition-colors font-medium flex-shrink-0">
          Скачать бэкап
        </button>
        <button data-action="snooze-backup" class="text-white/25 hover:text-white/50 transition-colors text-xs flex-shrink-0">Позже</button>
      </div>`
  }

  async function saveTimerState() {
    if (!currentSession) return
    await sb.from('projects_data').upsert(
      { user_id: currentSession.user.id, data: appData, updated_at: new Date().toISOString() },
      { onConflict: 'user_id' }
    )
  }

  function restoreTimerFromData() {
    if (appData.activeTimer) {
      activeTimer = appData.activeTimer
      startTimerTick()
      updateHeaderTimer()
      setFavicon(true, Math.floor((Date.now() - activeTimer.startedAt) / 1000))
    }
  }

  async function startTimer(projId, stId, taskId) {
    if (activeTimer) await stopTimer()
    const proj = getProject(projId)
    const st = proj.subtasks.find(s => s.id === stId)
    const task = st.tasks.find(t => t.id === taskId)
    activeTimer = { projId, stId, taskId, projTitle: proj.title, stTitle: st.title, taskTitle: task.title, startedAt: Date.now() }
    appData.activeTimer = activeTimer
    startTimerTick()
    updateTimerButtons()
    setFavicon(true)
    saveTimerState()
  }

  async function stopTimer() {
    if (!activeTimer) return
    const entry = { ...activeTimer }
    const duration = Math.round((Date.now() - entry.startedAt) / 1000)
    activeTimer = null
    delete appData.activeTimer
    clearInterval(timerInterval)
    timerInterval = null
    updateTimerButtons()
    setFavicon(false)
    document.title = ORIGINAL_TITLE
    saveTimerState()
    if (duration >= 5) await saveTimeEntry(entry, duration)
  }

  async function saveTimeEntry(entry, duration) {
    if (!currentSession) return
    await sb.from('time_entries').insert({
      user_id: currentSession.user.id,
      project_id: entry.projId,
      project_title: entry.projTitle,
      task_id: entry.taskId,
      task_title: entry.taskTitle,
      subtask_id: entry.stId,
      subtask_title: entry.stTitle,
      started_at: new Date(entry.startedAt).toISOString(),
      ended_at: new Date().toISOString(),
      duration_seconds: duration
    })
  }

  async function renderTodayActivity() {
    const container = document.getElementById('today-activity')
    if (!container || !currentSession) return
    const boardProjIds = projects().map(p => p.id)
    if (!boardProjIds.length) return
    const today = new Date(); today.setHours(0,0,0,0)
    const { data, error } = await sb
      .from('time_entries')
      .select('*')
      .eq('user_id', currentSession.user.id)
      .in('project_id', boardProjIds)
      .gte('started_at', today.toISOString())
      .order('started_at', { ascending: false })
    if (error || !data?.length) return
    const totalSeconds = data.reduce((sum, e) => sum + e.duration_seconds, 0)

    // group by project, preserving first-seen order
    const byProject = new Map()
    for (const e of data) {
      if (!byProject.has(e.project_id)) byProject.set(e.project_id, { title: e.project_title, id: e.project_id, entries: [] })
      byProject.get(e.project_id).entries.push(e)
    }

    const projectsHTML = [...byProject.values()].map(proj => {
      const projTotal = proj.entries.reduce((s, e) => s + e.duration_seconds, 0)
      const tasksHTML = proj.entries.map(e => {
        const start = new Date(e.started_at)
        return `<div
          data-action="open-tracked-task"
          data-project-id="${e.project_id}"
          data-task-id="${e.task_id}"
          class="flex items-center gap-3 hover:bg-white/4 rounded-lg px-2 py-2 cursor-pointer transition-colors">
          <div class="flex-1 min-w-0">
            <div class="text-sm text-white/65 truncate">${esc(e.task_title)}</div>
            ${e.subtask_title ? `<div class="text-xs text-white/25 truncate">${esc(e.subtask_title)}</div>` : ''}
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-sm font-mono font-medium text-white/50">${fmtDuration(e.duration_seconds)}</div>
            <div class="text-xs text-white/25">${fmtHHMM(start)}</div>
          </div>
        </div>`
      }).join('')

      return `
        <div class="bg-[#282e33] rounded-xl overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-white/5 cursor-pointer hover:bg-white/3 transition-colors"
            data-action="open-project" data-project-id="${proj.id}">
            <span class="text-sm font-semibold text-white/80">${esc(proj.title)}</span>
            <span class="text-sm font-mono font-medium text-white/50">${fmtDuration(projTotal)}</span>
          </div>
          <div class="px-2 py-1">${tasksHTML}</div>
        </div>`
    }).join('')

    container.innerHTML = `
      <div class="mt-4 border-t border-white/5 pt-5">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-semibold text-white/40">Сегодня</span>
          <div class="flex items-center gap-3">
            <span class="text-sm font-mono font-medium text-white/50">${fmtDuration(totalSeconds)}</span>
            <button data-action="go-history" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">История →</button>
          </div>
        </div>
        <div class="flex flex-col gap-3">${projectsHTML}</div>
      </div>`
  }

  async function renderProjectTimeHistory(projId) {
    const container = document.getElementById('project-time-history')
    if (!container || !currentSession) return
    const { data, error } = await sb
      .from('time_entries')
      .select('*')
      .eq('user_id', currentSession.user.id)
      .eq('project_id', projId)
      .order('started_at', { ascending: false })
      .limit(200)
    if (error || !data?.length) {
      container.innerHTML = `
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold text-white/50">Трекинг времени</span>
        </div>
        <p class="text-white/20 text-sm text-center py-6">Нет записей — запусти таймер на таске ▶</p>`
      return
    }
    const totalSeconds = data.reduce((sum, e) => sum + e.duration_seconds, 0)
    const byDay = new Map()
    for (const e of data) {
      const d = new Date(e.started_at)
      const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`
      if (!byDay.has(key)) byDay.set(key, { date: d, entries: [] })
      byDay.get(key).entries.push(e)
    }
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const dayNames = ['вс','пн','вт','ср','чт','пт','сб']
    const todayMidnight = new Date(); todayMidnight.setHours(0,0,0,0)
    let html = `
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm font-semibold text-white/50">Трекинг времени</span>
        <span class="text-sm font-mono font-medium text-white/50">итого: ${fmtDuration(totalSeconds)}</span>
      </div>
      <div class="flex flex-col gap-4">`
    for (const [, { date, entries }] of byDay) {
      const dayTotal = entries.reduce((s, e) => s + e.duration_seconds, 0)
      const dMid = new Date(date); dMid.setHours(0,0,0,0)
      const diff = Math.round((todayMidnight - dMid) / 86400000)
      const dateLabel = diff === 0 ? 'Сегодня' : diff === 1 ? 'Вчера' : `${dayNames[date.getDay()]}, ${date.getDate()} ${months[date.getMonth()]}`
      html += `
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xs font-semibold text-white/40 uppercase tracking-wider">${dateLabel}</span>
            <div class="flex-1 h-px bg-white/5"></div>
            <span class="text-xs font-mono text-white/35">${fmtDuration(dayTotal)}</span>
          </div>
          <div class="flex flex-col gap-1.5">
            ${entries.map(e => {
              const start = new Date(e.started_at)
              const end = new Date(e.ended_at)
              return `
                <div class="flex items-center gap-3 bg-white/3 hover:bg-white/5 rounded-lg px-3 py-2.5 group/entry transition-colors">
                  <div class="w-1 h-8 rounded-full bg-blue-500/40 flex-shrink-0"></div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm text-white/75 truncate">${esc(e.task_title)}</div>
                    ${e.subtask_title ? `<div class="text-xs text-white/35 truncate">${esc(e.subtask_title)}</div>` : ''}
                  </div>
                  <div class="text-xs text-white/30 flex-shrink-0 hidden sm:block">${fmtHHMM(start)}–${fmtHHMM(end)}</div>
                  <span
                    data-action="edit-time-entry"
                    data-entry-id="${e.id}"
                    data-started-at="${e.started_at}"
                    data-ended-at="${e.ended_at}"
                    class="text-sm font-mono font-medium text-white/60 cursor-pointer hover:text-blue-300 hover:underline transition-colors flex-shrink-0"
                    title="Нажми чтобы изменить"
                  >${fmtDuration(e.duration_seconds)}</span>
                  <button
                    data-action="delete-time-entry"
                    data-entry-id="${e.id}"
                    class="opacity-0 group-hover/entry:opacity-100 transition-opacity text-white/20 hover:text-red-400 text-xs flex-shrink-0 px-1"
                  >✕</button>
                </div>`
            }).join('')}
          </div>
        </div>`
    }
    html += `</div>`
    container.innerHTML = html
  }

  async function renderHistory() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
    const app = document.getElementById('app')
    app.innerHTML = `
      <div class="p-5 max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-5">
          <h1 class="text-lg font-bold text-white/70 flex-1">История времени</h1>
          <select id="history-filter" class="bg-[#282e33] border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white/60 focus:outline-none">
            <option value="">Все проекты</option>
          </select>
        </div>
        <div id="history-content" class="text-white/30 text-sm text-center py-12">Загрузка...</div>
      </div>`
    if (!currentSession) return
    const boardProjIds = projects().map(p => p.id)
    let query = sb.from('time_entries').select('*').eq('user_id', currentSession.user.id)
    if (boardProjIds.length) query = query.in('project_id', boardProjIds)
    else query = query.eq('project_id', 'none')
    const { data, error } = await query.order('started_at', { ascending: false }).limit(500)
    if (error) { document.getElementById('history-content').textContent = 'Ошибка загрузки'; return }
    if (!data?.length) {
      document.getElementById('history-content').innerHTML = `
        <div class="text-center py-12">
          <div class="text-4xl mb-3">⏱</div>
          <p class="text-white/30 text-sm">Нет записей. Запусти таймер на таске чтобы начать.</p>
        </div>`
      return
    }
    const projects = [...new Map(data.map(e => [e.project_id, e.project_title])).entries()]
    const filterEl = document.getElementById('history-filter')
    projects.forEach(([id, title]) => {
      const opt = document.createElement('option')
      opt.value = id; opt.textContent = title
      filterEl.appendChild(opt)
    })
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const dayNames = ['вс','пн','вт','ср','чт','пт','сб']
    function renderEntries(filterProjId) {
      const filtered = filterProjId ? data.filter(e => e.project_id === filterProjId) : data
      if (!filtered.length) {
        document.getElementById('history-content').innerHTML = `<p class="text-center py-8 text-white/25">Нет записей по этому проекту</p>`
        return
      }
      const byDay = new Map()
      for (const e of filtered) {
        const d = new Date(e.started_at)
        const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`
        if (!byDay.has(key)) byDay.set(key, { date: d, entries: [] })
        byDay.get(key).entries.push(e)
      }
      const todayMidnight = new Date(); todayMidnight.setHours(0,0,0,0)
      let html = ''
      for (const [, { date, entries }] of byDay) {
        const totalSecs = entries.reduce((s, e) => s + e.duration_seconds, 0)
        const dMid = new Date(date); dMid.setHours(0,0,0,0)
        const diff = Math.round((todayMidnight - dMid) / 86400000)
        const dateLabel = diff === 0 ? 'Сегодня' : diff === 1 ? 'Вчера' : `${dayNames[date.getDay()]}, ${date.getDate()} ${months[date.getMonth()]}`
        html += `
          <div class="mb-6">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white/60">${dateLabel}</span>
              <span class="text-sm font-mono font-medium text-white/40">${fmtDuration(totalSecs)}</span>
            </div>
            <div class="flex flex-col gap-2">
              ${entries.map(e => {
                const start = new Date(e.started_at)
                const end = new Date(e.ended_at)
                return `<div class="flex items-center gap-3 bg-[#282e33] rounded-lg px-3 py-2.5">
                  <div class="flex-1 min-w-0">
                    <div class="text-sm text-white/80 truncate">${esc(e.task_title)}</div>
                    <div class="text-xs text-white/35 truncate">${esc(e.project_title)}${e.subtask_title ? ' › ' + esc(e.subtask_title) : ''}</div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="text-sm font-mono font-medium text-white/70">${fmtDuration(e.duration_seconds)}</div>
                    <div class="text-xs text-white/30">${fmtHHMM(start)}–${fmtHHMM(end)}</div>
                  </div>
                </div>`
              }).join('')}
            </div>
          </div>`
      }
      document.getElementById('history-content').innerHTML = html
    }
    renderEntries('')
    filterEl.addEventListener('change', () => renderEntries(filterEl.value))
  }

  // ─── JOURNAL ─────────────────────────────────────────────────────────────────
  function journalEntries() {
    if (!appData.journal) appData.journal = []
    return appData.journal
  }

  function journalDateKey(y, m, d) {
    return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`
  }

  function renderJournal() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
    const app = document.getElementById('app')

    const MONTHS = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь']
    const DAY_NAMES = ['вс','пн','вт','ср','чт','пт','сб']
    const today = todayKey()
    const daysInMonth = new Date(journalYear, journalMonth + 1, 0).getDate()
    const entries = journalEntries()
    const entryMap = new Map(entries.map(e => [e.date, e]))

    const rows = []
    for (let d = 1; d <= daysInMonth; d++) {
      const dateKey = journalDateKey(journalYear, journalMonth, d)
      const dow = new Date(journalYear, journalMonth, d).getDay()
      const isToday = dateKey === today
      const isWeekend = dow === 0 || dow === 6
      const entry = entryMap.get(dateKey)
      const content = entry?.content || ''
      const sport = entry?.sport || false
      const steps = entry?.steps || ''
      const designDone = (designGymData().days[dateKey] || []).length
      rows.push({ d, dateKey, dow, isToday, isWeekend, content, sport, steps, designDone })
    }

    const sportIcon = (active) => active
      ? `<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`
      : `<span class="w-4 h-4 rounded-full border border-white/15 inline-block"></span>`

    app.innerHTML = `
      <div class="p-5 max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-5">
          <h1 class="text-lg font-bold text-white/70">Дневник</h1>
          <div class="flex items-center gap-1 ml-4">
            <button id="journal-prev" class="text-white/30 hover:text-white/70 transition-colors px-2 py-1 rounded-md hover:bg-white/5 text-sm">‹</button>
            <span class="text-sm font-medium text-white/60 min-w-[130px] text-center">${MONTHS[journalMonth]} ${journalYear}</span>
            <button id="journal-next" class="text-white/30 hover:text-white/70 transition-colors px-2 py-1 rounded-md hover:bg-white/5 text-sm">›</button>
          </div>
          <span id="journal-saved" class="ml-auto text-xs text-white/20 transition-opacity opacity-0">Сохранено</span>
        </div>

        <div class="bg-[#282e33] rounded-2xl overflow-hidden">
          <table class="w-full border-collapse">
            <thead>
              <tr class="border-b border-white/5">
                <th class="text-left text-xs text-white/25 font-medium px-4 py-2.5 w-10">day</th>
                <th class="text-left text-xs text-white/25 font-medium px-2 py-2.5 w-10">week</th>
                <th class="text-left text-xs text-white/25 font-medium px-3 py-2.5">note</th>
                <th class="text-center text-xs text-white/25 font-medium px-2 py-2.5 w-20">activity</th>
              </tr>
            </thead>
            <tbody>
              ${rows.map(({ d, dateKey, dow, isToday, isWeekend, content, sport, steps, designDone }) => `
                <tr class="border-b border-white/[0.04] group/row ${isToday ? 'bg-blue-500/8' : isWeekend ? 'bg-white/[0.015]' : ''}"
                    data-journal-row="${dateKey}">
                  <td class="px-4 py-0 align-middle">
                    <span class="text-sm tabular-nums ${isToday ? 'text-blue-400 font-semibold' : isWeekend ? 'text-white/35' : 'text-white/45'}">${d}</span>
                  </td>
                  <td class="px-2 py-0 align-middle">
                    <span class="text-xs ${isWeekend ? 'text-white/25' : 'text-white/30'}">${DAY_NAMES[dow]}</span>
                  </td>
                  <td class="px-3 py-1.5 align-middle">
                    <div class="flex items-center gap-2">
                      <div
                        contenteditable="true"
                        data-journal-cell="${dateKey}"
                        class="flex-1 text-sm outline-none min-h-[28px] py-1 leading-relaxed ${isToday ? 'text-white/80' : 'text-white/55'} empty:before:content-[attr(data-placeholder)] empty:before:text-white/15 empty:before:pointer-events-none focus:before:hidden"
                        data-placeholder="${isToday ? 'What did you do today?' : ''}"
                      >${esc(content)}</div>
                      ${designDone > 0 ? `<span class="flex-shrink-0 text-[10px] text-purple-400/70 bg-purple-400/10 px-1.5 py-0.5 rounded-full whitespace-nowrap">🎨 ${designDone}</span>` : ''}
                    </div>
                  </td>
                  <td class="px-2 py-0 align-middle text-center">
                    <button data-sport-toggle="${dateKey}" class="inline-flex items-center justify-center w-7 h-7 rounded-md hover:bg-white/5 transition-colors">
                      ${sportIcon(sport)}
                    </button>
                  </td>
                </tr>`).join('')}
            </tbody>
          </table>
        </div>
      </div>`

    document.getElementById('journal-prev').addEventListener('click', () => {
      journalMonth--
      if (journalMonth < 0) { journalMonth = 11; journalYear-- }
      renderJournal()
    })
    document.getElementById('journal-next').addEventListener('click', () => {
      journalMonth++
      if (journalMonth > 11) { journalMonth = 0; journalYear++ }
      renderJournal()
    })

    const savedEl = document.getElementById('journal-saved')

    function journalSaveField(dateKey, fields) {
      const entries = journalEntries()
      let idx = entries.findIndex(e => e.date === dateKey)
      if (idx < 0) { entries.push({ id: uid(), date: dateKey, content: '', createdAt: Date.now() }); idx = entries.length - 1 }
      Object.assign(entries[idx], fields)
      const e = entries[idx]
      if (!e.content && !e.sport && !e.steps) entries.splice(idx, 1)
      save()
      savedEl.style.opacity = '1'
      setTimeout(() => { savedEl.style.opacity = '0' }, 1800)
      if (dateKey === today && fields.content && fields.content.trim()) {
        const log = todayLog()
        if (!log.qJournal) {
          log.qJournal = true
          save()
        }
      }
    }

    app.querySelectorAll('[data-sport-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const dateKey = btn.dataset.sportToggle
        const entries = journalEntries()
        const entry = entries.find(e => e.date === dateKey)
        const newVal = !(entry?.sport || false)
        journalSaveField(dateKey, { sport: newVal })
        btn.innerHTML = sportIcon(newVal)
      })
    })

    let jSaveTimer = null
    app.querySelectorAll('[data-steps-cell]').forEach(input => {
      input.addEventListener('input', () => {
        clearTimeout(jSaveTimer)
        jSaveTimer = setTimeout(() => {
          const dateKey = input.dataset.stepsCell
          const steps = input.value.replace(/\D/g, '')
          input.value = steps
          journalSaveField(dateKey, { steps })
        }, 600)
      })
    })

    app.querySelectorAll('[data-journal-cell]').forEach(cell => {
      cell.addEventListener('input', () => {
        clearTimeout(jSaveTimer)
        savedEl.style.opacity = '0'
        jSaveTimer = setTimeout(() => {
          const dateKey = cell.dataset.journalCell
          const content = cell.innerText.trim()
          journalSaveField(dateKey, { content })
        }, 600)
      })
      cell.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault()
          const row = cell.closest('tr')
          const next = row?.nextElementSibling?.querySelector('[data-journal-cell]')
          if (next) next.focus()
        }
      })
    })

    if (today.startsWith(`${journalYear}-${String(journalMonth+1).padStart(2,'0')}`)) {
      const todayCell = app.querySelector(`[data-journal-cell="${today}"]`)
      if (todayCell) todayCell.focus()
    }
  }


