    const boardProjIds = projects().map(p => p.id)
    let query = sb.from('time_entries').select('*').eq('user_id', currentSession.user.id)
    if (boardProjIds.length) query = query.in('project_id', boardProjIds)
    else query = query.eq('project_id', 'none')
