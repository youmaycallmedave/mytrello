            class="text-xs text-blue-400 hover:text-blue-300 transition-colors font-medium">+ Добавить</button>
        </div>
        <div id="notes-container" class="flex flex-col gap-3">
          ${notesHtml}
        </div>
        ${notes.length === 0 ? `
          <div class="bg-[#282e33]/50 border border-white/5 border-dashed rounded-xl p-4 text-center">
            <p class="text-white/25 text-xs">Доступы, комменты клиента,<br>ссылки — всё сюда</p>
          </div>` : ''}
      </div>`
  }

  function renderSubtaskSection(proj, st) {
    const { done, total, pct } = subtaskProgress(st)
    const allDone = total > 0 && done === total
    const checkmark = `<svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`

    const tasksHtml = st.tasks.map(task => {
      const isActive = activeTimer?.taskId === task.id && activeTimer?.stId === st.id
      const initSecs = isActive ? Math.floor((Date.now() - activeTimer.startedAt) / 1000) : 0
      const c = isActive ? timerColor(initSecs) : null
      const rowStyle = isActive ? `border-left:3px solid ${c}99;background-color:${c}12;border-radius:0 8px 8px 0;padding-left:6px` : ''
      const timerBtn = isActive
        ? `<span style="display:flex;align-items:center;gap:4px"><span data-timer-dot style="width:7px;height:7px;border-radius:50%;background:${c};animation:pulse 1.5s ease-in-out infinite"></span><svg width="9" height="9" viewBox="0 0 9 9" fill="currentColor"><rect x="1" y="1" width="7" height="7" rx="1.5"/></svg></span>`
