---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Trello</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-[#1d2125] text-white min-h-screen font-sans antialiased">

  <header class="sticky top-0 z-40 bg-[#1d2125]/95 backdrop-blur border-b border-white/5 h-12 flex items-center px-4 gap-3">
    <button id="btn-home" class="flex items-center gap-2 hover:opacity-70 transition-opacity flex-shrink-0">
      <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4 5a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5zm9 0a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2V5zm0 9a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2v-5zM4 14a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5z"/>
      </svg>
      <span class="font-semibold text-sm">My Trello</span>
    </button>
    <div id="header-breadcrumb" class="hidden items-center gap-2 text-sm min-w-0">
      <span class="text-white/30">/</span>
      <span id="header-project-name" class="text-white/70 truncate"></span>
    </div>
    <div id="header-timer" class="hidden items-center gap-2 text-xs bg-red-500/10 border border-red-500/15 px-2.5 py-1 rounded-lg">
      <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse flex-shrink-0"></span>
      <span id="header-timer-task" class="truncate max-w-[110px] text-white/60"></span>
      <span id="header-timer-display" class="font-mono font-medium tabular-nums text-red-300"></span>
      <button id="btn-stop-timer" class="text-red-400/70 hover:text-red-300 transition-colors leading-none ml-0.5">⏹</button>
    </div>
    <div class="ml-auto flex items-center gap-2 flex-shrink-0">
      <button id="btn-history"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        История
      </button>
      <span id="header-user-email" class="hidden text-xs text-white/30 max-w-[160px] truncate"></span>
      <button id="btn-new-project"
        class="hidden text-xs bg-blue-600 hover:bg-blue-500 transition-colors px-3 py-1.5 rounded-md font-medium">
        + Новый проект
      </button>
      <button id="btn-logout"
        class="hidden text-xs text-white/30 hover:text-white/60 transition-colors px-2 py-1.5 rounded-md hover:bg-white/5">
        Выйти
      </button>
    </div>
  </header>

  <main id="app"></main>

  <div id="modal-overlay" class="hidden fixed inset-0 bg-black/70 z-50 flex items-start justify-center pt-16 px-4">
    <div class="bg-[#282e33] rounded-xl shadow-2xl w-full max-w-md relative">
      <button id="modal-close" class="absolute top-3 right-3 text-white/30 hover:text-white/70 transition-colors text-lg leading-none">✕</button>
      <div id="modal-body"></div>
    </div>
  </div>

  <script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js'

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )

  // ─── CONSTANTS ───────────────────────────────────────────────────────────────
  const COLORS = [
    { id: 'blue',   hex: ['#1e3a8a','#1e40af'] },
    { id: 'green',  hex: ['#14532d','#166534'] },
    { id: 'purple', hex: ['#4c1d95','#6d28d9'] },
    { id: 'red',    hex: ['#7f1d1d','#991b1b'] },
    { id: 'orange', hex: ['#7c2d12','#9a3412'] },
    { id: 'teal',   hex: ['#134e4a','#0f766e'] },
    { id: 'pink',   hex: ['#831843','#9d174d'] },
    { id: 'slate',  hex: ['#0f172a','#1e293b'] },
  ]

const STATUSES = {
    todo:       { label: 'Нужно сделать', color: 'bg-gray-100 text-gray-500',           dot: 'bg-gray-400' },
    inprogress: { label: 'В работе',      color: 'bg-blue-100 text-blue-700',            dot: 'bg-blue-500' },
    pending:    { label: 'На апруве',     color: 'bg-yellow-100 text-yellow-700',        dot: 'bg-yellow-500' },
    archived:   { label: 'Архив',         color: 'bg-green-100 text-green-700',          dot: 'bg-green-500' },
  }

  // ─── STATE ───────────────────────────────────────────────────────────────────
  const STORAGE_KEY = 'my-trello-v2'
  let appData = { projects: [] }
  let currentProjectId = null
  let homeTab = 'inprogress'
  let saveTimer = null
  let dbSaveTimer = null
  let currentSession = null
  let dataLoaded = false
  const collapsed = new Set()
  let activeTimer = null  // { projId, stId, taskId, projTitle, stTitle, taskTitle, startedAt }
  let timerInterval = null

  // ─── UTILS ───────────────────────────────────────────────────────────────────
  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 6)
  }
  function esc(s) {
    return String(s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;')
  }

  // ─── STORAGE ─────────────────────────────────────────────────────────────────
  function loadLocal() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (raw) appData = JSON.parse(raw)
    } catch (_) {}
    if (!appData.projects?.length) seedDemo()
  }

  async function loadFromDB() {
    const { data, error } = await sb
      .from('projects_data')
      .select('data')
      .single()
    if (error || !data) {
      // no DB row yet — fall back to localStorage (migration)
      loadLocal()
      return
    }
    appData = data.data
    localStorage.setItem(STORAGE_KEY, JSON.stringify(appData))
  }

  function save() {
    clearTimeout(saveTimer)
    saveTimer = setTimeout(() => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(appData))
    }, 300)
    saveToDB()
  }

  function saveToDB() {
    if (!currentSession) return
    clearTimeout(dbSaveTimer)
    dbSaveTimer = setTimeout(async () => {
      await sb.from('projects_data').upsert(
        { user_id: currentSession.user.id, data: appData, updated_at: new Date().toISOString() },
        { onConflict: 'user_id' }
      )
    }, 1500)
  }

  // ─── DEMO DATA ───────────────────────────────────────────────────────────────
  function seedDemo() {
    appData = {
      projects: [
        {
          id: uid(), title: 'Собрать сайт', color: 'blue', updatedAt: Date.now(), deadline: null, status: 'inprogress', priority: 2,
          subtasks: [
            {
              id: uid(), title: 'Главная страница',
              tasks: [
                { id: uid(), title: 'Hero секция', done: true },
                { id: uid(), title: 'Навигация', done: true },
                { id: uid(), title: 'Секция с фичами', done: false },
                { id: uid(), title: 'Футер', done: false },
              ]
            },
            {
              id: uid(), title: 'Страница «О нас»',
              tasks: [
                { id: uid(), title: 'Написать текст', done: false },
                { id: uid(), title: 'Добавить фото', done: false },
              ]
            },
            {
              id: uid(), title: 'Деплой',
              tasks: [
                { id: uid(), title: 'GitHub репо', done: true },
                { id: uid(), title: 'Подключить Vercel', done: false },
              ]
            },
          ],
          notes: [
            { id: uid(), title: '🔑 Доступы', content: 'FTP: ftp.example.com\nLogin: admin\nPass: ...' },
            { id: uid(), title: '💬 Клиент', content: 'Иванов Иван\nTelegram: @ivanov\nХочет синий цвет, без анимаций' },
          ]
        },
      ]
    }
  }

  function getProject(id) { return appData.projects.find(p => p.id === id) }

  function touchProject(id) {
    const p = getProject(id)
    if (p) p.updatedAt = Date.now()
  }

  function saveProject() {
    if (currentProjectId) touchProject(currentProjectId)
    save()
  }

  function elapsedSince(ts) {
    if (!ts) return '—'
    const diff = Math.max(0, Math.floor((Date.now() - ts) / 60000))
    const d = Math.floor(diff / 1440)
    const h = Math.floor((diff % 1440) / 60)
    const m = diff % 60
    if (d > 0) return `${d}д ${h}ч ${m}м`
    if (h > 0) return `${h}ч ${m}м`
    return `${m}м`
  }

  // ─── TIMER ───────────────────────────────────────────────────────────────────
  function fmtDuration(seconds) {
    if (seconds < 60) return `${seconds}с`
    const m = Math.floor(seconds / 60)
    const h = Math.floor(m / 60)
    if (h > 0) return `${h}ч ${m % 60}м`
    return `${m}м`
  }

  function fmtHHMM(date) {
    return `${String(date.getHours()).padStart(2,'0')}:${String(date.getMinutes()).padStart(2,'0')}`
  }

  function startTimerTick() {
    clearInterval(timerInterval)
    timerInterval = setInterval(() => {
      if (!activeTimer) { clearInterval(timerInterval); timerInterval = null; return }
      const el = document.getElementById('header-timer-display')
      if (el) el.textContent = fmtDuration(Math.floor((Date.now() - activeTimer.startedAt) / 1000))
    }, 1000)
  }

  function updateTimerButtons() {
    document.querySelectorAll('[data-timer-task-id]').forEach(btn => {
      const isActive = activeTimer &&
        btn.dataset.timerTaskId === activeTimer.taskId &&
        btn.dataset.timerStId === activeTimer.stId
      if (isActive) {
        btn.textContent = '⏹'
        btn.className = btn.className
          .replace('text-white/20','text-red-400')
          .replace('opacity-0 group-hover/task:opacity-100','opacity-100')
      } else {
        btn.textContent = '▶'
        btn.className = btn.className
          .replace('text-red-400','text-white/20')
          .replace('opacity-100','opacity-0 group-hover/task:opacity-100')
      }
    })
    updateHeaderTimer()
  }

  function updateHeaderTimer() {
    const hdr = document.getElementById('header-timer')
    if (!hdr) return
    if (activeTimer) {
      hdr.classList.remove('hidden')
      hdr.classList.add('flex')
      const taskEl = document.getElementById('header-timer-task')
      if (taskEl) taskEl.textContent = activeTimer.taskTitle
      const dispEl = document.getElementById('header-timer-display')
      if (dispEl) dispEl.textContent = fmtDuration(Math.floor((Date.now() - activeTimer.startedAt) / 1000))
    } else {
      hdr.classList.add('hidden')
      hdr.classList.remove('flex')
    }
  }

  async function startTimer(projId, stId, taskId) {
    if (activeTimer) await stopTimer()
    const proj = getProject(projId)
    const st = proj.subtasks.find(s => s.id === stId)
    const task = st.tasks.find(t => t.id === taskId)
    activeTimer = { projId, stId, taskId, projTitle: proj.title, stTitle: st.title, taskTitle: task.title, startedAt: Date.now() }
    startTimerTick()
    updateTimerButtons()
  }

  async function stopTimer() {
    if (!activeTimer) return
    const entry = { ...activeTimer }
    const duration = Math.round((Date.now() - entry.startedAt) / 1000)
    activeTimer = null
    clearInterval(timerInterval)
    timerInterval = null
    updateTimerButtons()
    if (duration >= 5) await saveTimeEntry(entry, duration)
  }

  async function saveTimeEntry(entry, duration) {
    if (!currentSession) return
    await sb.from('time_entries').insert({
      user_id: currentSession.user.id,
      project_id: entry.projId,
      project_title: entry.projTitle,
      task_id: entry.taskId,
      task_title: entry.taskTitle,
      subtask_id: entry.stId,
      subtask_title: entry.stTitle,
      started_at: new Date(entry.startedAt).toISOString(),
      ended_at: new Date().toISOString(),
      duration_seconds: duration
    })
  }

  async function renderTodayActivity() {
    const container = document.getElementById('today-activity')
    if (!container || !currentSession) return
    const today = new Date(); today.setHours(0,0,0,0)
    const { data, error } = await sb
      .from('time_entries')
      .select('*')
      .eq('user_id', currentSession.user.id)
      .gte('started_at', today.toISOString())
      .order('started_at', { ascending: false })
    if (error || !data?.length) return
    const totalSeconds = data.reduce((sum, e) => sum + e.duration_seconds, 0)
    container.innerHTML = `
      <div class="mt-4 border-t border-white/5 pt-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-semibold text-white/40">Сегодня</span>
          <div class="flex items-center gap-3">
            <span class="text-sm font-mono font-medium text-white/50">${fmtDuration(totalSeconds)}</span>
            <button data-action="go-history" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">История →</button>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          ${data.slice(0,8).map(e => {
            const start = new Date(e.started_at)
            return `<div class="flex items-center gap-3 bg-[#282e33] rounded-lg px-3 py-2.5">
              <div class="w-1 h-8 rounded-full bg-blue-500/40 flex-shrink-0"></div>
              <div class="flex-1 min-w-0">
                <div class="text-sm text-white/70 truncate">${esc(e.task_title)}</div>
                <div class="text-xs text-white/30 truncate">${esc(e.project_title)}${e.subtask_title ? ' › ' + esc(e.subtask_title) : ''}</div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-mono font-medium text-white/60">${fmtDuration(e.duration_seconds)}</div>
                <div class="text-xs text-white/30">${fmtHHMM(start)}</div>
              </div>
            </div>`
          }).join('')}
          ${data.length > 8 ? `<div class="text-xs text-center text-white/25 py-1">+${data.length-8} ещё</div>` : ''}
        </div>
      </div>`
  }

  async function renderProjectTimeHistory(projId) {
    const container = document.getElementById('project-time-history')
    if (!container || !currentSession) return
    const { data, error } = await sb
      .from('time_entries')
      .select('*')
      .eq('user_id', currentSession.user.id)
      .eq('project_id', projId)
      .order('started_at', { ascending: false })
      .limit(100)
    if (error || !data?.length) {
      container.innerHTML = `
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-white/40 uppercase tracking-wider">Время</span>
        </div>
        <p class="text-white/20 text-xs text-center py-3">Нет записей</p>`
      return
    }
    const totalSeconds = data.reduce((sum, e) => sum + e.duration_seconds, 0)
    const byDay = new Map()
    for (const e of data) {
      const d = new Date(e.started_at)
      const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`
      if (!byDay.has(key)) byDay.set(key, { date: d, entries: [] })
      byDay.get(key).entries.push(e)
    }
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const dayNames = ['вс','пн','вт','ср','чт','пт','сб']
    const todayMidnight = new Date(); todayMidnight.setHours(0,0,0,0)
    let html = `
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold text-white/40 uppercase tracking-wider">Время</span>
        <span class="text-xs font-mono font-medium text-white/50">${fmtDuration(totalSeconds)}</span>
      </div>
      <div class="flex flex-col gap-3 max-h-[420px] overflow-y-auto pr-1">`
    for (const [, { date, entries }] of byDay) {
      const dayTotal = entries.reduce((s, e) => s + e.duration_seconds, 0)
      const dMid = new Date(date); dMid.setHours(0,0,0,0)
      const diff = Math.round((todayMidnight - dMid) / 86400000)
      const dateLabel = diff === 0 ? 'Сегодня' : diff === 1 ? 'Вчера' : `${dayNames[date.getDay()]} ${date.getDate()} ${months[date.getMonth()]}`
      html += `
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs text-white/35 font-medium">${dateLabel}</span>
            <span class="text-xs font-mono text-white/35">${fmtDuration(dayTotal)}</span>
          </div>
          ${entries.map(e => {
            const start = new Date(e.started_at)
            return `<div class="flex items-start gap-2 py-1 pl-2 border-l-2 border-blue-500/25 mb-1.5">
              <div class="flex-1 min-w-0">
                <div class="text-xs text-white/65 truncate">${esc(e.task_title)}</div>
                ${e.subtask_title ? `<div class="text-xs text-white/30 truncate">${esc(e.subtask_title)}</div>` : ''}
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-xs font-mono text-white/55">${fmtDuration(e.duration_seconds)}</div>
                <div class="text-xs text-white/25">${fmtHHMM(start)}</div>
              </div>
            </div>`
          }).join('')}
        </div>`
    }
    html += `</div>`
    container.innerHTML = html
  }

  async function renderHistory() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
    const app = document.getElementById('app')
    app.innerHTML = `
      <div class="p-5 max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-5">
          <h1 class="text-lg font-bold text-white/70 flex-1">История времени</h1>
          <select id="history-filter" class="bg-[#282e33] border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white/60 focus:outline-none">
            <option value="">Все проекты</option>
          </select>
        </div>
        <div id="history-content" class="text-white/30 text-sm text-center py-12">Загрузка...</div>
      </div>`
    if (!currentSession) return
    const { data, error } = await sb
      .from('time_entries')
      .select('*')
      .eq('user_id', currentSession.user.id)
      .order('started_at', { ascending: false })
      .limit(500)
    if (error) { document.getElementById('history-content').textContent = 'Ошибка загрузки'; return }
    if (!data?.length) {
      document.getElementById('history-content').innerHTML = `
        <div class="text-center py-12">
          <div class="text-4xl mb-3">⏱</div>
          <p class="text-white/30 text-sm">Нет записей. Запусти таймер на таске чтобы начать.</p>
        </div>`
      return
    }
    const projects = [...new Map(data.map(e => [e.project_id, e.project_title])).entries()]
    const filterEl = document.getElementById('history-filter')
    projects.forEach(([id, title]) => {
      const opt = document.createElement('option')
      opt.value = id; opt.textContent = title
      filterEl.appendChild(opt)
    })
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const dayNames = ['вс','пн','вт','ср','чт','пт','сб']
    function renderEntries(filterProjId) {
      const filtered = filterProjId ? data.filter(e => e.project_id === filterProjId) : data
      if (!filtered.length) {
        document.getElementById('history-content').innerHTML = `<p class="text-center py-8 text-white/25">Нет записей по этому проекту</p>`
        return
      }
      const byDay = new Map()
      for (const e of filtered) {
        const d = new Date(e.started_at)
        const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`
        if (!byDay.has(key)) byDay.set(key, { date: d, entries: [] })
        byDay.get(key).entries.push(e)
      }
      const todayMidnight = new Date(); todayMidnight.setHours(0,0,0,0)
      let html = ''
      for (const [, { date, entries }] of byDay) {
        const totalSecs = entries.reduce((s, e) => s + e.duration_seconds, 0)
        const dMid = new Date(date); dMid.setHours(0,0,0,0)
        const diff = Math.round((todayMidnight - dMid) / 86400000)
        const dateLabel = diff === 0 ? 'Сегодня' : diff === 1 ? 'Вчера' : `${dayNames[date.getDay()]}, ${date.getDate()} ${months[date.getMonth()]}`
        html += `
          <div class="mb-6">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white/60">${dateLabel}</span>
              <span class="text-sm font-mono font-medium text-white/40">${fmtDuration(totalSecs)}</span>
            </div>
            <div class="flex flex-col gap-2">
              ${entries.map(e => {
                const start = new Date(e.started_at)
                const end = new Date(e.ended_at)
                return `<div class="flex items-center gap-3 bg-[#282e33] rounded-lg px-3 py-2.5">
                  <div class="flex-1 min-w-0">
                    <div class="text-sm text-white/80 truncate">${esc(e.task_title)}</div>
                    <div class="text-xs text-white/35 truncate">${esc(e.project_title)}${e.subtask_title ? ' › ' + esc(e.subtask_title) : ''}</div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="text-sm font-mono font-medium text-white/70">${fmtDuration(e.duration_seconds)}</div>
                    <div class="text-xs text-white/30">${fmtHHMM(start)}–${fmtHHMM(end)}</div>
                  </div>
                </div>`
              }).join('')}
            </div>
          </div>`
      }
      document.getElementById('history-content').innerHTML = html
    }
    renderEntries('')
    filterEl.addEventListener('change', () => renderEntries(filterEl.value))
  }

  function timeAgo(ts) {
    if (!ts) return null
    const diff = Date.now() - ts
    const mins = Math.floor(diff / 60000)
    if (mins < 2) return 'только что'
    if (mins < 60) return `${mins} мин назад`
    const hrs = Math.floor(mins / 60)
    if (hrs < 24) return `${hrs} ч назад`
    const days = Math.floor(hrs / 24)
    if (days === 1) return 'вчера'
    if (days < 7) return `${days} дн назад`
    if (days < 30) return `${Math.floor(days / 7)} нед назад`
    return `${Math.floor(days / 30)} мес назад`
  }

  function deadlineInfo(dateStr) {
    if (!dateStr) return null
    const today = new Date(); today.setHours(0,0,0,0)
    const dl = new Date(dateStr); dl.setHours(0,0,0,0)
    const diffDays = Math.round((dl - today) / 86400000)
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const label = diffDays < 0
      ? `просрочен на ${Math.abs(diffDays)} дн`
      : diffDays === 0 ? 'сегодня'
      : diffDays === 1 ? 'завтра'
      : diffDays <= 6 ? `через ${diffDays} дн`
      : `до ${dl.getDate()} ${months[dl.getMonth()]}`
    const urgency = diffDays < 0 ? 'red'
      : diffDays === 0 ? 'orange'
      : diffDays <= 2 ? 'yellow'
      : 'normal'
    return { label, urgency, diffDays }
  }

  function sortProjects(projects) {
    return [...projects].sort((a, b) => {
      const ad = deadlineInfo(a.deadline)
      const bd = deadlineInfo(b.deadline)
      // overdue first
      const aOverdue = ad && ad.diffDays < 0
      const bOverdue = bd && bd.diffDays < 0
      if (aOverdue !== bOverdue) return aOverdue ? -1 : 1
      // then by deadline (soonest first)
      const aDl = a.deadline ? new Date(a.deadline).getTime() : Infinity
      const bDl = b.deadline ? new Date(b.deadline).getTime() : Infinity
      if (aDl !== bDl) return aDl - bDl
      // then least recently updated first (most neglected)
      return (a.updatedAt || 0) - (b.updatedAt || 0)
    })
  }

  // ─── PROGRESS ────────────────────────────────────────────────────────────────
  function projectProgress(proj) {
    const tasks = proj.subtasks.flatMap(s => s.tasks)
    if (!tasks.length) return { done: 0, total: 0, pct: 0 }
    const done = tasks.filter(t => t.done).length
    return { done, total: tasks.length, pct: Math.round(done / tasks.length * 100) }
  }
  function subtaskProgress(st) {
    const total = st.tasks.length
    if (!total) return { done: 0, total: 0, pct: 0 }
    const done = st.tasks.filter(t => t.done).length
    return { done, total, pct: Math.round(done / total * 100) }
  }

