            </button>`).join('')}
        </div>
        <input id="home-search" type="search" placeholder="Поиск..." value="${esc(homeSearch)}"
          class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-blue-500/60 placeholder-white/25 text-white/80 w-44"/>
      </div>
      <div id="cards-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        ${renderCardsHTML()}
      </div>
      <div id="today-activity"></div>
    </div>`
    app.innerHTML = html
    renderTodayActivity()
    initHomeDragDrop()

    document.getElementById('home-search').addEventListener('input', e => {
      homeSearch = e.target.value
      document.getElementById('cards-container').innerHTML = renderCardsHTML()
      initHomeDragDrop()
    })
  }

  function renderCardsHTML() {
    const q = homeSearch.trim().toLowerCase()
    const filtered = projects()
      .filter(p => (p.status || 'inprogress') === homeTab)
      .filter(p => !q || p.title.toLowerCase().includes(q))

    if (!filtered.length) return `<div class="col-span-3 py-12 text-center text-white/25 text-sm">
      ${q ? `Ничего не найдено по «${esc(homeSearch)}»` : 'Нет проектов в этой категории'}
    </div>`

    return filtered.map(proj => {
      const { done, total, pct } = projectProgress(proj)
      const allDone = total > 0 && done === total
      const dl = deadlineInfo(proj.deadline)
      const dlBadgeColor = !dl ? '' :
        dl.urgency === 'red'    ? 'bg-red-500/20 text-red-700' :
        dl.urgency === 'orange' ? 'bg-orange-500/15 text-orange-700' :
        dl.urgency === 'yellow' ? 'bg-yellow-500/15 text-yellow-700' :
                                  'bg-black/8 text-gray-500'
      return `
        <div data-action="open-project" data-project-id="${proj.id}"
          data-drag-project
          draggable="true"
          class="rounded-xl cursor-pointer hover:scale-[1.02] transition-all duration-200 group overflow-hidden border border-black/8 flex flex-col shadow-sm bg-white select-none">
          <div class="px-4 pt-4 pb-3 flex-1">
            <div class="flex items-start justify-between mb-2.5">
              <div class="flex items-start gap-1.5 flex-1 min-w-0">
                <span class="drag-handle opacity-0 group-hover:opacity-100 cursor-grab text-gray-300 select-none text-base flex-shrink-0 mt-0.5 transition-opacity">⠿</span>
                <h2 class="font-bold text-base leading-tight text-gray-900">${esc(proj.title)}</h2>
              </div>
              <button data-action="delete-project" data-project-id="${proj.id}"
                class="opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-gray-700 text-sm flex-shrink-0 mt-0.5 ml-2">✕</button>
            </div>
            ${dl ? `<div class="mb-2.5"><span class="text-xs font-medium px-2 py-0.5 rounded-full ${dlBadgeColor}">⏱ ${dl.label}</span></div>` : ''}
            <div class="h-1.5 bg-black/8 rounded-full overflow-hidden mb-1.5">
              <div class="h-full rounded-full transition-all duration-500 ${allDone ? 'bg-green-500' : 'bg-blue-500'}"
                style="width:${pct}%"></div>
            </div>
            <div class="flex items-center justify-between text-xs mb-3">
              <span class="${allDone ? 'text-green-600 font-medium' : 'text-gray-500'}">${done} из ${total} готово</span>
              <span class="font-semibold ${allDone ? 'text-green-600' : 'text-gray-600'}">${pct}%</span>
            </div>
          </div>
          ${(() => {
            const pending = proj.subtasks.flatMap(s => s.tasks).filter(t => !t.done).slice(0, 5)
            if (!pending.length) return ''
            return `<div class="px-4 pb-3 flex flex-col gap-1">
              ${pending.map(t => `<div class="flex items-center gap-1.5 text-xs text-gray-500">
                <span class="w-3 h-3 rounded border border-gray-300 flex-shrink-0"></span>
                <span class="truncate">${esc(t.title)}</span>
              </div>`).join('')}
            </div>`
          })()}
          <div class="px-4 pb-3 pt-2 flex items-center justify-between border-t border-black/6 mt-1">
            <span class="text-xs text-gray-400">с последнего апдейта</span>
            <span id="elapsed-${proj.id}" class="text-xs font-mono font-medium text-gray-400 tabular-nums">
              ${elapsedSince(proj.updatedAt)}
            </span>
          </div>
        </div>`
    }).join('')
  }

  // ─── CRM ─────────────────────────────────────────────────────────────────────
  function crm() {
    if (!appData.crm) appData.crm = { clients: [], projects: [] }
    return appData.crm
  }
  function crmClientProjects(clientId) { return crm().projects.filter(p => p.clientId === clientId) }
  function crmClient(id) { return crm().clients.find(c => c.id === id) }
  function crmProject(id) { return crm().projects.find(p => p.id === id) }

  function crmResetHeader() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
  }

  function fmtMoney(n) { return n != null && n !== '' ? Number(n).toLocaleString('ru-RU') : '' }
  function fmtDate(d) {
    if (!d) return ''
    const [y, m, day] = d.split('-')
    return `${day}.${m}.${y}`
  }

