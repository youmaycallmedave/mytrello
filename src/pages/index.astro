            data-project-id="${proj.id}" data-note-id="${note.id}"
          >${esc(note.title)}</span>
          <button
            data-action="insert-link"
            data-project-id="${proj.id}" data-note-id="${note.id}"
            class="opacity-0 group-hover/note:opacity-100 transition-opacity text-white/30 hover:text-blue-400 text-xs flex-shrink-0 px-0.5"
            title="Вставить ссылку (Ctrl+K)">🔗</button>
          <button
            data-action="delete-note"
