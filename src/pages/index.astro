  // ─── AUTH UI ─────────────────────────────────────────────────────────────────
  function showHeaderAuth(session) {
    const emailEl = document.getElementById('header-user-email')
    const logoutBtn = document.getElementById('btn-logout')
    const historyBtn = document.getElementById('btn-history')
    const journalBtn = document.getElementById('btn-journal')
    const designGymBtn = document.getElementById('btn-design-gym')
    const backupBtn = document.getElementById('btn-backup')
    const coinsBtn = document.getElementById('btn-coins')
    if (session) {
      emailEl.textContent = session.user.email
      emailEl.classList.remove('hidden')
      logoutBtn.classList.remove('hidden')
      historyBtn?.classList.remove('hidden')
      journalBtn?.classList.remove('hidden')
      designGymBtn?.classList.remove('hidden')
      backupBtn?.classList.remove('hidden')
      coinsBtn?.classList.remove('hidden')
      coinsBtn?.classList.add('flex')
    } else {
      emailEl.classList.add('hidden')
      logoutBtn.classList.add('hidden')
      historyBtn?.classList.add('hidden')
      journalBtn?.classList.add('hidden')
      designGymBtn?.classList.add('hidden')
      backupBtn?.classList.add('hidden')
      coinsBtn?.classList.add('hidden')
      coinsBtn?.classList.remove('flex')
