  function renderAuth() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
    showHeaderAuth(null)

    document.getElementById('app').innerHTML = `
      <div class="flex flex-col items-center justify-center min-h-[70vh] px-4">
        <div class="w-full max-w-sm">
          <div class="text-center mb-8">
            <div class="text-5xl mb-3">📋</div>
            <h1 class="text-2xl font-bold mb-1">My Trello</h1>
            <p class="text-white/40 text-sm">Войди чтобы начать</p>
          </div>
          <div class="bg-[#282e33] rounded-2xl p-6 shadow-xl">
            <div id="auth-msg" class="hidden text-sm text-center mb-4 px-3 py-2 rounded-lg"></div>
            <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Email</label>
            <input id="auth-email" type="email" placeholder="you@example.com" autocomplete="email"
              class="w-full bg-[#1d2125] border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500 mb-3"/>
            <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Пароль</label>
            <input id="auth-password" type="password" placeholder="••••••••" autocomplete="current-password"
              class="w-full bg-[#1d2125] border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500 mb-4"/>
            <button id="auth-signin-btn"
              class="w-full bg-blue-600 hover:bg-blue-500 transition-colors rounded-xl py-3 text-sm font-semibold mb-2">
              Войти
            </button>
            <button id="auth-signup-btn"
              class="w-full text-white/35 hover:text-white/60 transition-colors py-2 text-sm">
              Нет аккаунта? Создать
            </button>
          </div>
        </div>
      </div>`

    const showMsg = (text, isError = true) => {
      const el = document.getElementById('auth-msg')
      el.textContent = text
      el.className = `text-sm text-center mb-4 px-3 py-2 rounded-lg ${isError ? 'bg-red-500/15 text-red-300' : 'bg-blue-500/15 text-blue-300'}`
      el.classList.remove('hidden')
    }

    const getFields = () => ({
      email: document.getElementById('auth-email').value.trim(),
      password: document.getElementById('auth-password').value
    })

    document.getElementById('auth-signin-btn').addEventListener('click', async () => {
      const { email, password } = getFields()
      if (!email || !password) { showMsg('Введи email и пароль'); return }
      const btn = document.getElementById('auth-signin-btn')
      btn.textContent = 'Входим...'; btn.disabled = true
      const { error } = await sb.auth.signInWithPassword({ email, password })
      btn.textContent = 'Войти'; btn.disabled = false
      if (error) showMsg(error.message === 'Invalid login credentials' ? 'Неверный email или пароль' : error.message)
    })

    document.getElementById('auth-signup-btn').addEventListener('click', async () => {
      const { email, password } = getFields()
      if (!email || !password) { showMsg('Введи email и пароль'); return }
      if (password.length < 6) { showMsg('Пароль минимум 6 символов'); return }
      const btn = document.getElementById('auth-signup-btn')
      btn.textContent = 'Создаём...'; btn.disabled = true
      const { error } = await sb.auth.signUp({ email, password })
      btn.textContent = 'Нет аккаунта? Создать'; btn.disabled = false
      if (error) { showMsg(error.message); return }
      showMsg('Аккаунт создан — теперь войди', false)
    })

    const onEnter = e => { if (e.key === 'Enter') document.getElementById('auth-signin-btn').click() }
    document.getElementById('auth-email').addEventListener('keydown', onEnter)
    document.getElementById('auth-password').addEventListener('keydown', onEnter)
  }

  // ─── ROUTING ─────────────────────────────────────────────────────────────────
  function route() {
    const hash = location.hash
    if (hash === '#history') { currentProjectId = null; renderHistory(); return }
    currentProjectId = hash.startsWith('#p/') ? hash.slice(3) : null
    render()
  }
  function go(path) { location.hash = path }

  // ─── RENDER ──────────────────────────────────────────────────────────────────
  function render() {
    if (currentProjectId) {
      // if target task is in a collapsed subtask — uncollapse first
      if (pendingScrollTaskId) {
        const proj = getProject(currentProjectId)
        if (proj) {
          for (const st of proj.subtasks) {
            if (st.tasks.some(t => t.id === pendingScrollTaskId) && collapsed.has(st.id)) {
              collapsed.delete(st.id); break
            }
          }
        }
      }
      renderProject(); initDragDrop(); renderProjectTimeHistory(currentProjectId)
      if (pendingScrollTaskId) {
        const taskId = pendingScrollTaskId
        pendingScrollTaskId = null
        setTimeout(() => {
          const el = document.querySelector(`[data-task-id="${taskId}"]`)
          if (!el) return
          el.scrollIntoView({ behavior: 'smooth', block: 'center' })
          el.style.transition = 'background-color 0.5s'
          el.style.backgroundColor = 'rgba(59,130,246,0.18)'
          setTimeout(() => { el.style.backgroundColor = '' }, 1800)
        }, 120)
      }
    } else renderHome()
  }

  function renderBoardTabs() {
    const wrap = document.getElementById('board-tabs')
    if (!wrap) return
    const canDelete = appData.boards.length > 1
    wrap.innerHTML = (appData.boards || []).map(b => `
      <div class="relative group/board flex items-center">
        <button data-action="switch-board" data-board-id="${b.id}"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium transition-all pr-${canDelete ? '5' : '2.5'}
            ${b.id === appData.activeBoardId
              ? 'bg-white/10 text-white'
              : 'text-white/35 hover:text-white/65 hover:bg-white/5'}">
          <span>${b.emoji}</span>
          <span class="hidden sm:inline">${esc(b.name)}</span>
        </button>
        ${canDelete ? `<button data-action="delete-board" data-board-id="${b.id}" data-board-name="${esc(b.name)}"
          class="absolute right-0.5 top-1/2 -translate-y-1/2 opacity-0 group-hover/board:opacity-100 transition-opacity
            text-white/30 hover:text-red-400 text-[10px] leading-none px-0.5 py-0.5 rounded"
          title="Удалить доску">✕</button>` : ''}
      </div>`).join('') +
      `<button data-action="new-board"
        class="flex items-center px-1.5 py-1 rounded-lg text-xs text-white/25 hover:text-white/60 hover:bg-white/5 transition-all ml-0.5"
        title="Новая доска">+</button>`
  }

  function renderHome() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.remove('hidden')
    renderBoardTabs()

    const app = document.getElementById('app')

    if (!projects().length) {
      app.innerHTML = `
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
          <div class="text-5xl mb-4">📋</div>
          <h2 class="text-xl font-bold mb-2">Нет проектов</h2>
          <p class="text-white/40 text-sm mb-6">Создай первый проект чтобы начать</p>
          <button data-action="new-project"
            class="bg-blue-600 hover:bg-blue-500 transition-colors px-5 py-2.5 rounded-lg font-medium text-sm">
            + Создать проект
          </button>
        </div>`
      return
    }

    const statuses = boardStatuses()
    const counts = {}
    for (const s of statuses) counts[s.id] = projects().filter(p => (p.status || statuses[0].id) === s.id).length
    if (!homeTab || !statuses.find(s => s.id === homeTab)) homeTab = smartDefaultTab()

    let html = `<div class="p-5 max-w-5xl mx-auto">
      ${backupBannerHTML()}
      <!-- tabs + search -->
      <div class="flex items-center gap-2 mb-5 flex-wrap">
        <div class="flex gap-1 flex-wrap flex-1">
          ${statuses.map(s => `
            <button data-action="set-tab" data-tab="${s.id}"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all"
              style="${homeTab === s.id ? `background:${s.color}22;color:${s.color}` : 'color:rgba(255,255,255,0.5)'}">
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:${s.color}"></span>
              ${esc(s.label)}
              ${counts[s.id] ? `<span class="text-xs" style="opacity:0.6">${counts[s.id]}</span>` : ''}
            </button>`).join('')}
        </div>
        <input id="home-search" type="search" placeholder="Поиск..." value="${esc(homeSearch)}"
          class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-blue-500/60 placeholder-white/25 text-white/80 w-44"/>
      </div>
      <div id="cards-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        ${renderCardsHTML()}
      </div>
      <div id="today-activity"></div>
    </div>`
    app.innerHTML = html
    renderTodayActivity()
    initHomeDragDrop()

    document.getElementById('home-search').addEventListener('input', e => {
      homeSearch = e.target.value
      document.getElementById('cards-container').innerHTML = renderCardsHTML()
      initHomeDragDrop()
    })
  }

  function renderCardsHTML() {
    const q = homeSearch.trim().toLowerCase()
    const filtered = projects()
      .filter(p => (p.status || 'inprogress') === homeTab)
      .filter(p => !q || p.title.toLowerCase().includes(q))

    if (!filtered.length) return `<div class="col-span-3 py-12 text-center text-white/25 text-sm">
      ${q ? `Ничего не найдено по «${esc(homeSearch)}»` : 'Нет проектов в этой категории'}
    </div>`

    return filtered.map(proj => {
      const { done, total, pct } = projectProgress(proj)
      const allDone = total > 0 && done === total
      const dl = deadlineInfo(proj.deadline)
      const dlBadgeColor = !dl ? '' :
        dl.urgency === 'red'    ? 'bg-red-500/20 text-red-700' :
        dl.urgency === 'orange' ? 'bg-orange-500/15 text-orange-700' :
        dl.urgency === 'yellow' ? 'bg-yellow-500/15 text-yellow-700' :
                                  'bg-black/8 text-gray-500'
      return `
        <div data-action="open-project" data-project-id="${proj.id}"
          data-drag-project
          draggable="true"
          class="rounded-xl cursor-pointer hover:scale-[1.02] transition-all duration-200 group overflow-hidden border border-black/8 flex flex-col shadow-sm bg-white select-none">
