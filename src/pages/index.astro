            class="note-content w-full bg-[#1d2125] rounded-lg px-3 py-2.5 text-sm text-white/80 focus:outline-none focus:ring-1 focus:ring-blue-500/50 leading-relaxed min-h-[80px] break-words"
          >${renderNoteContent(note.content || '')}</div>
