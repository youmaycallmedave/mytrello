            <div class="flex items-start justify-between mb-2.5">
              <div class="flex items-start gap-1.5 flex-1 min-w-0">
                <span class="drag-handle opacity-0 group-hover:opacity-100 cursor-grab text-gray-300 select-none text-base flex-shrink-0 mt-0.5 transition-opacity">⠿</span>
                <h2 class="font-bold text-base leading-tight text-gray-900">${esc(proj.title)}</h2>
              </div>
              <button data-action="delete-project" data-project-id="${proj.id}"
                class="opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-gray-700 text-sm flex-shrink-0 mt-0.5 ml-2">✕</button>
            </div>
            <div class="mb-2.5">
              ${(() => { const st = statusById(proj.status || boardStatuses()[0]?.id); return `
              <button data-action="cycle-status" data-project-id="${proj.id}"
                class="flex items-center gap-1.5 text-xs px-2 py-0.5 rounded-full transition-all hover:opacity-80"
                style="background:${st.color}18;color:${st.color}">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:${st.color}"></span>
                ${esc(st.label)}
              </button>` })()}
            </div>
            ${dl ? `<div class="mb-2.5"><span class="text-xs font-medium px-2 py-0.5 rounded-full ${dlBadgeColor}">⏱ ${dl.label}</span></div>` : ''}
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
              <span>${proj.subtasks.length} подзадач</span>
              <span class="text-gray-300">·</span>
              <span>${total} тасков</span>
            </div>
            <div class="h-1.5 bg-black/8 rounded-full overflow-hidden mb-1.5">
              <div class="h-full rounded-full transition-all duration-500 ${allDone ? 'bg-green-500' : 'bg-blue-500'}"
                style="width:${pct}%"></div>
            </div>
            <div class="flex items-center justify-between text-xs">
              <span class="${allDone ? 'text-green-600 font-medium' : 'text-gray-500'}">${done} из ${total} готово</span>
              <span class="font-semibold ${allDone ? 'text-green-600' : 'text-gray-600'}">${pct}%</span>
            </div>
          </div>
          ${proj.subtasks.length ? `
          <div class="px-4 pb-3 flex flex-wrap gap-1.5">
            ${proj.subtasks.slice(0,4).map(s => {
              const sp = subtaskProgress(s)
              return `<span class="text-xs bg-black/6 text-gray-600 px-2 py-0.5 rounded-full">
                ${esc(s.title)}${sp.total ? ` · ${sp.done}/${sp.total}` : ''}
              </span>`
            }).join('')}
            ${proj.subtasks.length > 4 ? `<span class="text-xs text-gray-400 px-1">+${proj.subtasks.length-4}</span>` : ''}
          </div>` : ''}
          <div class="px-4 pb-3 pt-2 flex items-center justify-between border-t border-black/6 mt-1">
            <span class="text-xs text-gray-400">с последнего апдейта</span>
            <span id="elapsed-${proj.id}" class="text-xs font-mono font-medium text-gray-400 tabular-nums">
              ${elapsedSince(proj.updatedAt)}
            </span>
          </div>
        </div>`
    }).join('')
  }

