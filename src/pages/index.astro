  function designGymData() {
    if (!appData.designGym) appData.designGym = { days: {}, doneIdx: [] }
    if (appData.designGym.completed && !appData.designGym.days) {
      appData.designGym.days = {}
      for (const date of appData.designGym.completed) appData.designGym.days[date] = []
      delete appData.designGym.completed
    }
    if (!appData.designGym.days) appData.designGym.days = {}
    if (!appData.designGym.doneIdx) appData.designGym.doneIdx = []
    return appData.designGym
  }

  function designCalcStreak() {
    const data = designGymData()
    let streak = 0
    const d = new Date(); d.setHours(0,0,0,0)
    while (true) {
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
      if (!(key in data.days)) break
      streak++
      d.setDate(d.getDate() - 1)
    }
    return streak
  }

  function renderDesignGym() {
    document.getElementById('header-breadcrumb').classList.add('hidden')
    document.getElementById('btn-new-project').classList.add('hidden')
    const app = document.getElementById('app')
    const data = designGymData()
    const today = todayKey()
    const doneSet = new Set(data.doneIdx)
    const todayDoneIdx = data.days[today] || []
    const streak = designCalcStreak()
    const total = DESIGN_TASKS.length
    const doneSoFar = doneSet.size

    const catColors = {
      '🤖': 'text-blue-400 bg-blue-400/10',
      '🔍': 'text-purple-400 bg-purple-400/10',
      '🔧': 'text-orange-400 bg-orange-400/10',
      '🎨': 'text-pink-400 bg-pink-400/10',
    }

    // Unlock tasks 10 at a time: next 10 unlock when 80% of current batch done
    let unlocked = 10
    while (doneSoFar >= Math.floor(unlocked * 0.8) && unlocked < DESIGN_TASKS.length) unlocked += 10
    unlocked = Math.min(unlocked, DESIGN_TASKS.length)
    const queue = DESIGN_TASKS.map((t, i) => ({ t, i })).filter(({ i }) => i < unlocked && !doneSet.has(i))
    const shown = queue.slice(0, 5)

    const last14 = []
    for (let i = 13; i >= 0; i--) {
      const d = new Date(); d.setDate(d.getDate() - i); d.setHours(0,0,0,0)
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
      const DAY_NAMES = ['вс','пн','вт','ср','чт','пт','сб']
      const cnt = key in data.days ? (data.days[key].length || 1) : 0
      last14.push({ key, day: d.getDate(), dow: DAY_NAMES[d.getDay()], cnt, isToday: key === today })
    }

    const pct = Math.round(doneSoFar / total * 100)
    const remaining = total - doneSoFar

    app.innerHTML = `
      <div class="p-5 max-w-2xl mx-auto">
        <div class="flex items-center gap-3 mb-4">
          <h1 class="text-lg font-bold text-white/70 flex-1">Дизайн</h1>
          ${streak > 0 ? `<div class="flex items-center gap-1.5 text-sm font-semibold text-orange-400"><span>🔥</span><span>${streak}</span></div>` : ''}
        </div>

        <div class="bg-[#282e33] rounded-2xl p-4 mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs text-white/40">Выполнено <span class="text-white/70 font-semibold">${doneSoFar}</span> из <span class="text-white/70 font-semibold">${unlocked}</span></span>
            <span class="text-xs ${queue.length <= 3 ? 'text-orange-400 font-medium' : 'text-white/25'}">осталось ${queue.length}</span>
          </div>
          <div class="h-1.5 bg-white/8 rounded-full overflow-hidden">
            <div class="h-full bg-blue-500 rounded-full transition-all duration-500" style="width:${Math.round(doneSoFar/unlocked*100)}%"></div>
          </div>
        </div>

        <div class="flex flex-col gap-3 mb-4">
          ${shown.length === 0 ? `
            <div class="text-center py-12 text-white/30 text-sm">
              <div class="text-4xl mb-3">🎉</div>
              Все задания выполнены! Скоро будут новые.
            </div>` :
          shown.map(({ t, i }) => {
            const doneToday = todayDoneIdx.includes(i)
            return `<div class="bg-[#282e33] rounded-2xl p-5 ${doneToday ? 'opacity-55' : ''}">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-medium px-2.5 py-1 rounded-full ${catColors[t.cat] || 'text-white/40 bg-white/5'}">${t.cat} ${t.label}</span>
              </div>
              <h2 class="text-sm font-semibold text-white/90 mb-1.5 leading-snug">${esc(t.title)}</h2>
              <p class="text-sm text-white/45 leading-relaxed ${t.tip ? 'mb-3' : 'mb-4'}">${esc(t.desc)}</p>
              ${t.tip ? `<div class="mb-4 text-xs text-amber-400/75 bg-amber-400/8 border border-amber-400/15 rounded-xl px-3 py-2.5 leading-relaxed">💡 ${esc(t.tip)}</div>` : ''}
              <button data-gym-task="${i}"
                class="w-full py-2 rounded-xl text-sm font-semibold transition-all
                  ${doneToday ? 'bg-green-500/15 hover:bg-red-500/12 text-green-400 hover:text-red-400' : 'bg-white/6 hover:bg-white/10 text-white/70'}">
                ${doneToday ? '✓ Выполнено' : 'Отметить как выполнено'}
              </button>
            </div>`
          }).join('')}
        </div>

        <div class="bg-[#282e33] rounded-2xl p-4">
          <div class="text-xs text-white/25 font-medium mb-3">Последние 14 дней</div>
          <div class="flex gap-1.5">
            ${last14.map(({ day, dow, cnt, isToday }) => `
              <div class="flex flex-col items-center gap-1 flex-1">
                <div class="text-[10px] text-white/20">${dow}</div>
                <div class="w-full aspect-square rounded-md flex items-center justify-center text-[11px] font-medium transition-all
                  ${cnt > 0 ? 'bg-green-500/25 text-green-400' : isToday ? 'bg-white/8 text-white/60 ring-1 ring-white/20' : 'bg-white/4 text-white/20'}">
                  ${cnt > 0 ? cnt : day}
                </div>
              </div>`).join('')}
          </div>
        </div>
      </div>`

    app.querySelectorAll('[data-gym-task]').forEach(btn => {
      const idx = parseInt(btn.dataset.gymTask)
      btn.addEventListener('click', () => {
        const data = designGymData()
        if (!data.days[today]) data.days[today] = []
        const alreadyDone = data.days[today].includes(idx)
        if (alreadyDone) {
          data.days[today] = data.days[today].filter(i => i !== idx)
          data.doneIdx = data.doneIdx.filter(i => i !== idx)
        } else {
          data.days[today].push(idx)
          if (!data.doneIdx.includes(idx)) data.doneIdx.push(idx)
        }
        save()
        renderDesignGym()
      })
    })
  }

  

    function deadlineInfo(dateStr) {
    if (!dateStr) return null
    const today = new Date(); today.setHours(0,0,0,0)
    const dl = new Date(dateStr); dl.setHours(0,0,0,0)
    const diffDays = Math.round((dl - today) / 86400000)
    const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек']
    const label = diffDays < 0
      ? `просрочен на ${Math.abs(diffDays)} дн`
      : diffDays === 0 ? 'сегодня'
      : diffDays === 1 ? 'завтра'
      : diffDays <= 6 ? `через ${diffDays} дн`
      : `до ${dl.getDate()} ${months[dl.getMonth()]}`
    const urgency = diffDays < 0 ? 'red'
      : diffDays === 0 ? 'orange'
      : diffDays <= 2 ? 'yellow'
      : 'normal'
    return { label, urgency, diffDays }
  }


  // ─── PROGRESS ────────────────────────────────────────────────────────────────
  function projectProgress(proj) {
    const tasks = proj.subtasks.flatMap(s => s.tasks)
    if (!tasks.length) return { done: 0, total: 0, pct: 0 }
    const done = tasks.filter(t => t.done).length
    return { done, total: tasks.length, pct: Math.round(done / tasks.length * 100) }
  }
  function subtaskProgress(st) {
    const total = st.tasks.length
    if (!total) return { done: 0, total: 0, pct: 0 }
    const done = st.tasks.filter(t => t.done).length
    return { done, total, pct: Math.round(done / total * 100) }
  }

  // ─── GAMIFICATION ────────────────────────────────────────────────────────────
  function gam() {
    if (!appData.gamification) appData.gamification = { coins: 0, coinLog: [], rewards: [] }
    return appData.gamification
  }

  function todayKey() {
    const d = new Date()
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
  }

  function todayLog() {
    const g = gam()
    let entry = g.coinLog.find(e => e.date === todayKey())
    if (!entry) { entry = { date: todayKey(), earned: 0, tasks: 0, q3: false, q5: false, qJournal: false }; g.coinLog.push(entry) }
    if (entry.qJournal === undefined) entry.qJournal = false
    return entry
  }

  // ─── TASK DONE ANIMATIONS ────────────────────────────────────────────────────
  function _spawnParticle(cx, cy, content, size, tx, ty, spin, dur, isEmoji) {
    const el = document.createElement('div')
    const ox = cx + (Math.random() - 0.5) * 14
    const oy = cy + (Math.random() - 0.5) * 8
    el.style.cssText = `position:fixed;left:${ox}px;top:${oy}px;z-index:9999;font-size:${size}px;pointer-events:none;transform:translate(-50%,-50%) scale(0) rotate(0deg);opacity:1;transition:none`
    el.textContent = content
    document.body.appendChild(el)
    requestAnimationFrame(() => requestAnimationFrame(() => {
      el.style.transition = `transform ${dur}ms cubic-bezier(0.15,0.85,0.25,1), opacity ${dur}ms ease`
      el.style.transform = `translate(calc(-50% + ${tx}px),calc(-50% + ${ty}px)) scale(1.1) rotate(${spin}deg)`
      setTimeout(() => {
        el.style.transition = 'opacity 250ms ease-in, transform 250ms ease-in'
        el.style.opacity = '0'
        el.style.transform = `translate(calc(-50% + ${tx}px),calc(-50% + ${ty + 16}px)) scale(0.3) rotate(${spin + 90}deg)`
        setTimeout(() => el.remove(), 260)
      }, dur - 80)
    }))
  }

  function _emojiBurst(cx, cy, emojis, count, spread, upBias) {
    for (let i = 0; i < count; i++) {
      setTimeout(() => {
        const angle = upBias
          ? -Math.PI / 2 + (Math.random() - 0.5) * Math.PI * spread
          : Math.random() * Math.PI * 2
        const dist = 38 + Math.random() * 58
        _spawnParticle(cx, cy,
          emojis[Math.floor(Math.random() * emojis.length)],
          13 + Math.random() * 6,
          Math.cos(angle) * dist, Math.sin(angle) * dist,
          (Math.random() - 0.5) * 540,
          440 + Math.random() * 220)
      }, i * 35 + Math.random() * 20)
    }
  }

  function _dotsBurst(cx, cy, colors, count) {
    for (let i = 0; i < count; i++) {
      setTimeout(() => {
        const el = document.createElement('div')
        const angle = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.4
        const dist = 32 + Math.random() * 48
        const size = 5 + Math.random() * 5
        const color = colors[Math.floor(Math.random() * colors.length)]
        const tx = Math.cos(angle) * dist, ty = Math.sin(angle) * dist
        el.style.cssText = `position:fixed;left:${cx}px;top:${cy}px;z-index:9999;width:${size}px;height:${size}px;border-radius:50%;background:${color};pointer-events:none;transform:translate(-50%,-50%) scale(0);transition:none`
        document.body.appendChild(el)
        requestAnimationFrame(() => requestAnimationFrame(() => {
          el.style.transition = 'transform 520ms cubic-bezier(0.2,0.9,0.3,1), opacity 520ms ease'
          el.style.transform = `translate(calc(-50% + ${tx}px),calc(-50% + ${ty}px)) scale(1)`
          el.style.opacity = '0'
          setTimeout(() => el.remove(), 560)
        }))
      }, i * 22)
    }
  }

  function _confettiBurst(cx, cy) {
    const colors = ['#f87171','#fb923c','#facc15','#4ade80','#60a5fa','#c084fc','#f472b6']
    for (let i = 0; i < 14; i++) {
      setTimeout(() => {
        const el = document.createElement('div')
        const angle = -Math.PI / 2 + (Math.random() - 0.5) * Math.PI * 1.6
        const dist = 28 + Math.random() * 72
        const w = 4 + Math.random() * 5, h = w + Math.random() * 5
        const color = colors[Math.floor(Math.random() * colors.length)]
        const tx = Math.cos(angle) * dist, ty = Math.sin(angle) * dist + Math.random() * 30
        const spin = (Math.random() - 0.5) * 400
        el.style.cssText = `position:fixed;left:${cx + (Math.random()-0.5)*16}px;top:${cy}px;z-index:9999;width:${w}px;height:${h}px;background:${color};border-radius:1px;pointer-events:none;transform:translate(-50%,-50%) scale(0) rotate(0deg);transition:none`
        document.body.appendChild(el)
        requestAnimationFrame(() => requestAnimationFrame(() => {
          el.style.transition = 'transform 650ms cubic-bezier(0.1,0.9,0.35,1), opacity 650ms ease'
          el.style.transform = `translate(calc(-50% + ${tx}px),calc(-50% + ${ty}px)) scale(1) rotate(${spin}deg)`
          el.style.opacity = '0'
          setTimeout(() => el.remove(), 700)
        }))
      }, i * 28)
    }
  }

  function _ringsBurst(cx, cy, color) {
    for (let i = 0; i < 3; i++) {
      setTimeout(() => {
        const el = document.createElement('div')
        el.style.cssText = `position:fixed;left:${cx}px;top:${cy}px;z-index:9999;width:12px;height:12px;border:2.5px solid ${color};border-radius:50%;pointer-events:none;transform:translate(-50%,-50%) scale(0);opacity:0.9;transition:none`
        document.body.appendChild(el)
        requestAnimationFrame(() => requestAnimationFrame(() => {
          el.style.transition = 'transform 580ms ease-out, opacity 580ms ease'
          el.style.transform = 'translate(-50%,-50%) scale(6)'
          el.style.opacity = '0'
          setTimeout(() => el.remove(), 620)
        }))
      }, i * 140)
    }
  }

  function _bigPop(cx, cy, emoji) {
    const el = document.createElement('div')
    el.style.cssText = `position:fixed;left:${cx}px;top:${cy}px;z-index:9999;font-size:32px;pointer-events:none;transform:translate(-50%,-50%) scale(0);transition:none`
    el.textContent = emoji
    document.body.appendChild(el)
    requestAnimationFrame(() => requestAnimationFrame(() => {
      el.style.transition = 'transform 0.38s cubic-bezier(0.2,1.5,0.4,1), opacity 0.7s ease 0.15s'
      el.style.transform = 'translate(-50%, calc(-50% - 28px)) scale(1.8)'
      el.style.opacity = '0'
      setTimeout(() => el.remove(), 900)
    }))
  }

  function showTaskDoneAnim(sourceEl) {
    const rect = sourceEl.getBoundingClientRect()
    const cx = rect.left + rect.width / 2
    const cy = rect.top + rect.height / 2
    const pick = Math.floor(Math.random() * 8)
    if (pick === 0) _emojiBurst(cx, cy, ['⭐','🌟'], 7, 1.4, false)
    else if (pick === 1) _emojiBurst(cx, cy, ['✨','💫'], 6, 1.6, false)
    else if (pick === 2) _emojiBurst(cx, cy, ['🔥'], 5, 0.9, true)
    else if (pick === 3) _emojiBurst(cx, cy, ['⚡'], 5, 1.8, false)
    else if (pick === 4) _confettiBurst(cx, cy)
    else if (pick === 5) _dotsBurst(cx, cy, ['#f87171','#fb923c','#facc15','#4ade80','#60a5fa','#c084fc'], 10)
    else if (pick === 6) { _ringsBurst(cx, cy, ['#3b82f6','#8b5cf6','#10b981','#f59e0b'][Math.floor(Math.random()*4)]); _emojiBurst(cx, cy, ['✓'], 4, 1.2, false) }
    else _bigPop(cx, cy, ['🎉','🎊','💥','🚀'][Math.floor(Math.random()*4)])
  }

