      return `
      <div
        class="flex items-center gap-1.5 rounded-lg hover:bg-white/5 group/task transition-colors"
        style="${rowStyle}"
        ${isActive ? 'data-active-task-row' : ''}
        draggable="true"
        data-drag-task
        data-proj-id="${proj.id}"
        data-st-id="${st.id}"
        data-task-id="${task.id}"
      >
        <span class="drag-handle opacity-0 group-hover/task:opacity-100 cursor-grab text-white/20 select-none text-base px-1 flex-shrink-0 transition-opacity">⠿</span>
        <label class="flex items-center flex-shrink-0 cursor-pointer py-1.5 pr-2">
          <input type="checkbox" ${task.done ? 'checked' : ''}
            data-action="toggle-task"
            data-project-id="${proj.id}" data-subtask-id="${st.id}" data-task-id="${task.id}"
            class="sr-only peer"/>
          <div class="w-4 h-4 rounded border-2 border-white/25 peer-checked:bg-blue-500 peer-checked:border-blue-500
            flex items-center justify-center transition-all pointer-events-none">
            ${task.done ? checkmark : ''}
          </div>
        </label>
        <span
          class="flex-1 text-sm py-1.5 cursor-text select-none ${task.done ? 'line-through text-white/30' : 'text-white/80'}"
          data-action="edit-task-title"
          data-project-id="${proj.id}" data-subtask-id="${st.id}" data-task-id="${task.id}"
        >${esc(task.title)}</span>
        <button
          data-action="toggle-timer"
          data-timer-task-id="${task.id}"
          data-timer-st-id="${st.id}"
          data-project-id="${proj.id}" data-subtask-id="${st.id}" data-task-id="${task.id}"
          class="flex-shrink-0 px-1.5 py-1.5 transition-all text-xs
            ${isActive ? 'text-white/70 opacity-100' : 'text-white/20 hover:text-green-400 opacity-0 group-hover/task:opacity-100'}"
        >${timerBtn}</button>
        <button data-action="delete-task"
          data-project-id="${proj.id}" data-subtask-id="${st.id}" data-task-id="${task.id}"
          class="opacity-0 group-hover/task:opacity-100 transition-opacity text-white/25 hover:text-red-400 text-xs flex-shrink-0 px-1.5 py-1.5">✕</button>
      </div>`
    }).join('')

    const isCollapsed = collapsed.has(st.id)

    return `
      <div
        class="bg-[#282e33] rounded-xl overflow-visible group/st"
        draggable="true"
        data-drag-subtask
        data-proj-id="${proj.id}"
        data-st-id="${st.id}"
      >
        <div class="px-3 pt-3 ${isCollapsed ? 'pb-3' : 'pb-2'}">
          <div class="flex items-center gap-1.5 mb-2.5">
            <span class="drag-handle opacity-0 group-hover/st:opacity-100 cursor-grab text-white/20 select-none text-base px-0.5 flex-shrink-0 transition-opacity">⠿</span>
            <!-- Collapse toggle -->
            <button
              data-action="toggle-collapse"
              data-subtask-id="${st.id}"
              class="flex-shrink-0 text-white/25 hover:text-white/60 transition-all"
              title="${isCollapsed ? 'Развернуть' : 'Свернуть'}"
            >
              <svg class="w-3.5 h-3.5 transition-transform duration-200 ${isCollapsed ? '' : 'rotate-90'}"
                fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
            <div class="w-2 h-2 rounded-full flex-shrink-0 ${allDone ? 'bg-green-400' : done > 0 ? 'bg-blue-400' : 'bg-white/20'}"></div>
            <h3
              class="font-semibold text-sm flex-1 cursor-text hover:text-blue-300 transition-colors min-w-0"
              data-action="edit-subtask-title"
              data-project-id="${proj.id}" data-subtask-id="${st.id}"
            >${esc(st.title)}</h3>
            <span class="text-xs ${allDone ? 'text-green-400' : 'text-white/35'} flex-shrink-0">${done}/${total}</span>
            <button data-action="delete-subtask" data-project-id="${proj.id}" data-subtask-id="${st.id}"
              class="text-white/20 hover:text-red-400 transition-colors text-xs flex-shrink-0 ml-1 px-1">✕</button>
          </div>
          <div class="h-1 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all duration-400 ${allDone ? 'bg-green-400' : 'bg-blue-400'}"
              style="width:${pct}%"></div>
          </div>
        </div>
        ${isCollapsed ? '' : `
        <div class="px-2 pt-1 pb-2 flex flex-col">${tasksHtml}</div>
        <div class="px-4 pb-3.5">
          <div id="add-task-form-${st.id}" class="hidden mb-2">
            <div class="flex gap-2">
              <input id="new-task-input-${st.id}" type="text" placeholder="Название таска..."
                data-project-id="${proj.id}" data-subtask-id="${st.id}"
                class="flex-1 bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500"/>
              <button data-action="confirm-add-task" data-project-id="${proj.id}" data-subtask-id="${st.id}"
                class="bg-blue-600 hover:bg-blue-500 transition-colors text-sm px-3 py-2 rounded-lg font-medium flex-shrink-0">+</button>
              <button data-action="cancel-add-task" data-subtask-id="${st.id}"
                class="text-white/30 hover:text-white/60 text-sm px-2">✕</button>
            </div>
          </div>
          <button data-action="show-add-task" data-subtask-id="${st.id}"
            class="text-xs text-white/35 hover:text-white/60 hover:bg-white/5 transition-colors rounded-lg px-2 py-1.5 flex items-center gap-1.5">
            <span class="text-sm leading-none">+</span> Добавить таск
          </button>
        </div>`}
      </div>`
  }


  function rerenderProject() {
    const scrollY = window.scrollY
    renderProject()
    initDragDrop()
    renderProjectTimeHistory(currentProjectId)
    window.scrollTo({ top: scrollY })
  }

  // ─── DRAG & DROP ─────────────────────────────────────────────────────────────
  let dragState = null
  let allowDrag = false

  function clearDragOver() {
    document.querySelectorAll('.drag-over-above, .drag-over-below')
      .forEach(el => el.classList.remove('drag-over-above', 'drag-over-below'))
  }

  function initDragDrop() {
    const container = document.getElementById('subtasks-container')
    if (!container) return

    // ── subtasks ──
    container.querySelectorAll('[data-drag-subtask]').forEach(el => {
      el.addEventListener('mousedown', e => {
        allowDrag = !!e.target.closest('.drag-handle')
      })
      el.addEventListener('dragstart', e => {
        if (!allowDrag) { e.preventDefault(); return }
        dragState = { type: 'subtask', projId: el.dataset.projId, stId: el.dataset.stId }
        el.classList.add('dragging')
        e.dataTransfer.effectAllowed = 'move'
      })
      el.addEventListener('dragend', () => {
        el.classList.remove('dragging')
        clearDragOver()
        dragState = null
      })
      el.addEventListener('dragover', e => {
        if (dragState?.type !== 'subtask' || el.dataset.stId === dragState.stId) return
        e.preventDefault()
        clearDragOver()
        const rect = el.getBoundingClientRect()
        el.classList.add(e.clientY < rect.top + rect.height / 2 ? 'drag-over-above' : 'drag-over-below')
      })
      el.addEventListener('drop', e => {
        if (dragState?.type !== 'subtask') return
        e.preventDefault()
        const isBelow = el.classList.contains('drag-over-below')
        clearDragOver()
        const proj = getProject(dragState.projId)
        const fromIdx = proj.subtasks.findIndex(s => s.id === dragState.stId)
        const [item] = proj.subtasks.splice(fromIdx, 1)
        let toIdx = proj.subtasks.findIndex(s => s.id === el.dataset.stId)
        if (toIdx === -1) toIdx = proj.subtasks.length
        else if (isBelow) toIdx++
        proj.subtasks.splice(toIdx, 0, item)
        saveProject(); rerenderProject()
      })
    })

    // ── tasks ──
    container.querySelectorAll('[data-drag-task]').forEach(el => {
      el.addEventListener('mousedown', e => {
        allowDrag = !!e.target.closest('.drag-handle')
      })
      el.addEventListener('dragstart', e => {
        if (!allowDrag) { e.preventDefault(); return }
        e.stopPropagation()
        dragState = { type: 'task', projId: el.dataset.projId, stId: el.dataset.stId, taskId: el.dataset.taskId }
        el.classList.add('dragging')
        e.dataTransfer.effectAllowed = 'move'
      })
      el.addEventListener('dragend', () => {
        el.classList.remove('dragging')
        clearDragOver()
        dragState = null
      })
      el.addEventListener('dragover', e => {
        if (dragState?.type !== 'task' || el.dataset.taskId === dragState.taskId) return
        e.preventDefault()
        e.stopPropagation()
        clearDragOver()
        const rect = el.getBoundingClientRect()
        el.classList.add(e.clientY < rect.top + rect.height / 2 ? 'drag-over-above' : 'drag-over-below')
      })
      el.addEventListener('drop', e => {
        if (dragState?.type !== 'task') return
        e.preventDefault()
        e.stopPropagation()
        const isBelow = el.classList.contains('drag-over-below')
        clearDragOver()
        const proj = getProject(dragState.projId)
        const srcSt = proj.subtasks.find(s => s.id === dragState.stId)
        const dstSt = proj.subtasks.find(s => s.id === el.dataset.stId)
        const fromIdx = srcSt.tasks.findIndex(t => t.id === dragState.taskId)
        if (fromIdx === -1) return
        const [task] = srcSt.tasks.splice(fromIdx, 1)
        let toIdx = dstSt.tasks.findIndex(t => t.id === el.dataset.taskId)
        if (toIdx === -1) toIdx = dstSt.tasks.length
        else if (isBelow) toIdx++
        dstSt.tasks.splice(toIdx, 0, task)
        saveProject(); rerenderProject()
      })
    })
  }

  function clearHomeDragOver() {
    document.querySelectorAll('.drag-over-proj-above, .drag-over-proj-below')
      .forEach(el => el.classList.remove('drag-over-proj-above', 'drag-over-proj-below'))
  }

  function initHomeDragDrop() {
    const container = document.getElementById('cards-container')
    if (!container) return
    container.querySelectorAll('[data-drag-project]').forEach(el => {
      el.addEventListener('mousedown', e => {
        allowDrag = !!e.target.closest('.drag-handle')
      })
      el.addEventListener('dragstart', e => {
        if (!allowDrag) { e.preventDefault(); return }
        dragState = { type: 'project', projId: el.dataset.projectId }
        el.classList.add('dragging')
        e.dataTransfer.effectAllowed = 'move'
      })
      el.addEventListener('dragend', () => {
        el.classList.remove('dragging')
        clearHomeDragOver()
        dragState = null
      })
      el.addEventListener('dragover', e => {
        if (dragState?.type !== 'project' || el.dataset.projectId === dragState.projId) return
        e.preventDefault()
        clearHomeDragOver()
        const rect = el.getBoundingClientRect()
        el.classList.add(e.clientY < rect.top + rect.height / 2 ? 'drag-over-proj-above' : 'drag-over-proj-below')
      })
      el.addEventListener('drop', e => {
        if (dragState?.type !== 'project') return
        e.preventDefault()
        const isBelow = el.classList.contains('drag-over-proj-below')
        clearHomeDragOver()
        const ps = projects()
        const fromIdx = ps.findIndex(p => p.id === dragState.projId)
        const [item] = ps.splice(fromIdx, 1)
        let toIdx = ps.findIndex(p => p.id === el.dataset.projectId)
        if (toIdx === -1) toIdx = ps.length
        else if (isBelow) toIdx++
        ps.splice(toIdx, 0, item)
        save()
        document.getElementById('cards-container').innerHTML = renderCardsHTML()
        initHomeDragDrop()
      })
    })
  }

  // ─── MODALS ──────────────────────────────────────────────────────────────────
  function openModal(html) {
    document.getElementById('modal-body').innerHTML = html
    document.getElementById('modal-overlay').classList.remove('hidden')
  }
  function closeModal() {
    document.getElementById('modal-overlay').classList.add('hidden')
    document.getElementById('modal-body').innerHTML = ''
  }

  function showNewProjectModal() {
    openModal(`
      <div class="p-5">
        <h2 class="text-base font-bold mb-4">Новый проект</h2>
        <input id="new-proj-input" type="text" placeholder="Название проекта..."
          class="w-full bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 mb-3"/>
        <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Папка</label>
        <div class="flex flex-wrap gap-2 mb-3">
          ${boardStatuses().map(s => `
            <button data-status-opt="${s.id}"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border-2 transition-all
                border-transparent bg-white/5 text-white/50 hover:text-white/80">
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:${s.color}"></span>
              ${esc(s.label)}
            </button>`).join('')}
        </div>
        <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Дедлайн <span class="normal-case text-white/20">(необязательно)</span></label>
        <input id="new-proj-deadline" type="date"
          class="w-full bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 mb-4 [color-scheme:dark]"/>
        <button data-action="confirm-new-project"
          class="w-full bg-blue-600 hover:bg-blue-500 transition-colors rounded-lg py-2.5 text-sm font-semibold">
          Создать проект
        </button>
      </div>`)

    window._newProjStatus = boardStatuses()[0]?.id
    document.querySelector(`[data-status-opt="${window._newProjStatus}"]`)?.classList.add('border-blue-500', 'text-white', '!bg-blue-500/15')

    document.querySelectorAll('[data-status-opt]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-status-opt]').forEach(b =>
          b.classList.remove('border-blue-500', 'text-white', '!bg-blue-500/15'))
        btn.classList.add('border-blue-500', 'text-white', '!bg-blue-500/15')
        window._newProjStatus = btn.dataset.statusOpt
      })
    })
    setTimeout(() => document.getElementById('new-proj-input').focus(), 40)
  }

  // ─── EVENTS ──────────────────────────────────────────────────────────────────
  document.addEventListener('click', async e => {
    if (e.target.id === 'modal-overlay' || e.target.id === 'modal-close') { closeModal(); return }

    // close status dropdown on outside click
    const dd = document.getElementById('status-dropdown')
    if (dd && !dd.classList.contains('hidden') && !e.target.closest('#status-badge-wrap')) {
      dd.classList.add('hidden')
    }

    const el = e.target.closest('[data-action]')
    if (!el) return
    const a = el.dataset.action

    if (a === 'delete-board') {
      e.stopPropagation()
      const { boardId, boardName } = el.dataset
      const board = appData.boards.find(b => b.id === boardId)
      const projCount = board?.projects.length || 0
      const msg = projCount > 0
        ? `Удалить доску «${boardName}»?\n\nВнутри ${projCount} проект(ов) со всеми подзадачами и таймером. Это действие нельзя отменить.`
        : `Удалить доску «${boardName}»?`
      if (!confirm(msg)) return
      appData.boards = appData.boards.filter(b => b.id !== boardId)
      if (appData.activeBoardId === boardId) appData.activeBoardId = appData.boards[0]?.id
      save(); homeTab = smartDefaultTab(); homeSearch = ''; currentProjectId = null; location.hash = ''; render(); return
    }
    if (a === 'switch-board') {
      appData.activeBoardId = el.dataset.boardId
      save(); homeTab = smartDefaultTab(); homeSearch = ''; currentProjectId = null; location.hash = ''; render(); return
    }
    if (a === 'new-board') {
      openModal(`
        <div class="p-5">
          <h2 class="text-base font-bold mb-4">Новая доска</h2>
          <div class="flex gap-2 mb-3">
            <input id="new-board-emoji" type="text" value="📁" maxlength="2"
              class="w-14 bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm text-center focus:outline-none focus:border-blue-500"/>
            <input id="new-board-name" type="text" placeholder="Название доски..."
              class="flex-1 bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500"/>
          </div>
          <button data-action="confirm-new-board"
            class="w-full bg-blue-600 hover:bg-blue-500 transition-colors rounded-lg py-2.5 text-sm font-semibold">
            Создать доску
          </button>
        </div>`)
      setTimeout(() => document.getElementById('new-board-name').focus(), 40)
      return
    }
    if (a === 'confirm-new-board') {
      const name = document.getElementById('new-board-name').value.trim()
      if (!name) { document.getElementById('new-board-name').focus(); return }
      const emoji = document.getElementById('new-board-emoji').value.trim() || '📁'
      const newBoard = { id: uid(), name, emoji, projects: [] }
      appData.boards.push(newBoard)
      appData.activeBoardId = newBoard.id
      save(); closeModal(); homeTab = smartDefaultTab(); homeSearch = ''; currentProjectId = null; location.hash = ''; render(); return
    }
    if (a === 'nav-home') { go(''); return }
    if (a === 'download-backup') { await downloadBackup(); return }
    if (a === 'snooze-backup') {
      localStorage.setItem(BACKUP_KEY, (Date.now() - 6 * 24 * 60 * 60 * 1000).toString())
      document.getElementById('backup-banner')?.remove(); return
    }
    if (a === 'open-gam-panel') { openGamPanel(); return }
    if (a === 'close-gam-panel') { closeGamPanel(); return }
    if (a === 'buy-reward') {
      const g = gam()
      const r = g.rewards.find(r => r.id === el.dataset.rewardId)
      if (!r || g.coins < r.cost) return
      g.coins -= r.cost
      r.bought = (r.bought || 0) + 1
      save(); updateGamUI(); renderGamPanelContent(); return
    }
    if (a === 'show-add-reward') {
      const form = document.getElementById('add-reward-form')
      if (form) { form.classList.toggle('hidden'); if (!form.classList.contains('hidden')) document.getElementById('reward-title-input')?.focus() }
      return
    }
    if (a === 'confirm-add-reward') {
      const title = document.getElementById('reward-title-input')?.value.trim()
      const cost = parseInt(document.getElementById('reward-cost-input')?.value)
      if (!title || !cost || cost < 1) return
      gam().rewards.push({ id: uid(), title, cost, bought: 0 })
      save(); renderGamPanelContent(); return
    }
    if (a === 'delete-reward') {
      gam().rewards = gam().rewards.filter(r => r.id !== el.dataset.rewardId)
      save(); renderGamPanelContent(); return
    }
    if (a === 'go-history') { go('history'); return }
    if (a === 'open-tracked-task') {
      pendingScrollTaskId = el.dataset.taskId
      go(`p/${el.dataset.projectId}`)
      return
    }
    if (a === 'delete-time-entry') {
      e.stopPropagation()
      if (!confirm('Удалить запись?')) return
      await sb.from('time_entries').delete().eq('id', el.dataset.entryId)
      renderProjectTimeHistory(currentProjectId)
      return
    }
    if (a === 'edit-time-entry') {
      e.stopPropagation()
      const { entryId, startedAt, endedAt } = el.dataset
      const toLocal = iso => {
        const d = new Date(iso)
        const p = n => String(n).padStart(2,'0')
        return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`
      }
      openModal(`
        <div class="p-5">
          <h2 class="text-base font-bold mb-4">Изменить запись</h2>
          <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Начало</label>
          <input id="entry-start" type="datetime-local" value="${toLocal(startedAt)}"
            class="w-full bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 mb-3 [color-scheme:dark]"/>
          <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">Конец</label>
          <input id="entry-end" type="datetime-local" value="${toLocal(endedAt)}"
            class="w-full bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 mb-1 [color-scheme:dark]"/>
          <p id="entry-error" class="hidden text-xs text-red-400 mb-3">Конец должен быть позже начала</p>
          <div class="mb-4"></div>
          <button id="entry-save"
            class="w-full bg-blue-600 hover:bg-blue-500 transition-colors rounded-lg py-2.5 text-sm font-semibold">
            Сохранить
          </button>
        </div>`)
      document.getElementById('entry-save').addEventListener('click', async () => {
        const start = new Date(document.getElementById('entry-start').value)
        const end = new Date(document.getElementById('entry-end').value)
        if (isNaN(start.getTime()) || isNaN(end.getTime()) || end <= start) {
          document.getElementById('entry-error').classList.remove('hidden'); return
        }
        document.getElementById('entry-save').textContent = 'Сохраняем...'
        await sb.from('time_entries').update({
          started_at: start.toISOString(),
          ended_at: end.toISOString(),
          duration_seconds: Math.round((end - start) / 1000)
        }).eq('id', entryId)
        closeModal()
        renderProjectTimeHistory(currentProjectId)
      })
      return
    }
    if (a === 'toggle-status-dropdown') {
      e.stopPropagation()
      const dd = document.getElementById('status-dropdown')
      if (dd) dd.classList.toggle('hidden')
      return
    }
    if (a === 'set-project-status') {
      e.stopPropagation()
      const proj = getProject(el.dataset.projectId)
      proj.status = el.dataset.status
      save(); rerenderProject(); return
    }
    if (a === 'toggle-timer') {
      e.stopPropagation()
      const { projectId, subtaskId, taskId } = el.dataset
      if (activeTimer && activeTimer.taskId === taskId && activeTimer.stId === subtaskId) {
        await stopTimer()
      } else {
        await startTimer(projectId, subtaskId, taskId)
      }
      return
    }
    if (a === 'set-tab') { homeTab = el.dataset.tab; renderHome(); return }
    if (a === 'cycle-status') {
      e.stopPropagation()
      const proj = getProject(el.dataset.projectId)
      const sts = boardStatuses()
      const cur = sts.findIndex(s => s.id === (proj.status || sts[0].id))
      proj.status = sts[(cur + 1) % sts.length].id
      save(); renderHome(); return
    }
    if (a === 'open-project') { e.stopPropagation(); go(`p/${el.dataset.projectId}`); return }
    if (a === 'new-project') { showNewProjectModal(); return }
    if (a === 'delete-project') {
      e.stopPropagation()
      if (!confirm('Удалить проект?')) return
      const _b = appData.boards.find(b => b.projects.some(p => p.id === el.dataset.projectId))
      if (_b) _b.projects = _b.projects.filter(p => p.id !== el.dataset.projectId)
      save(); render(); return
    }
    if (a === 'confirm-new-project') {
      const title = document.getElementById('new-proj-input').value.trim()
      if (!title) { document.getElementById('new-proj-input').focus(); return }
      const deadline = document.getElementById('new-proj-deadline')?.value || null
      const proj = { id: uid(), title, color: 'blue', subtasks: [], notes: [], updatedAt: Date.now(), deadline: deadline || null, status: window._newProjStatus || 'inprogress' }
      currentBoard().projects.push(proj)
      save(); closeModal(); go(`p/${proj.id}`); return
    }
    if (a === 'edit-project-title') {
      const proj = getProject(el.dataset.projectId)
      const h1 = document.querySelector('h1.text-2xl')
      if (!h1) return
      const inp = document.createElement('input')
      inp.type = 'text'; inp.value = proj.title
      inp.className = 'text-2xl font-bold bg-transparent border-b-2 border-blue-500 focus:outline-none flex-1 w-full'
      h1.replaceWith(inp); inp.focus(); inp.select()
      const done = () => { const v = inp.value.trim(); if (v) { proj.title = v; saveProject() }; rerenderProject() }
      inp.addEventListener('blur', done)
      inp.addEventListener('keydown', e2 => { if (e2.key === 'Enter') { e2.preventDefault(); done() } if (e2.key === 'Escape') rerenderProject() })
      return
    }
    if (a === 'edit-deadline') {
      const proj = getProject(el.dataset.projectId)
      openModal(`
        <div class="p-5">
          <h2 class="text-base font-bold mb-1">Дедлайн проекта</h2>
          <p class="text-xs text-white/40 mb-4">Установи дату — проект появится выше в списке когда срок приближается</p>
          <input id="deadline-input" type="date"
            value="${proj.deadline || ''}"
            class="w-full bg-[#1d2125] border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500 mb-4
              [color-scheme:dark]"/>
          <div class="flex gap-2">
            <button id="deadline-save"
              class="flex-1 bg-blue-600 hover:bg-blue-500 transition-colors rounded-xl py-2.5 text-sm font-semibold">
              Сохранить
            </button>
            ${proj.deadline ? `<button id="deadline-clear"
              class="text-white/30 hover:text-red-400 transition-colors text-sm px-4 py-2.5 rounded-xl hover:bg-white/5">
              Убрать
            </button>` : ''}
          </div>
        </div>`)
      document.getElementById('deadline-save').addEventListener('click', () => {
        const val = document.getElementById('deadline-input').value
        proj.deadline = val || null
        save(); closeModal(); rerenderProject()
      })
      document.getElementById('deadline-clear')?.addEventListener('click', () => {
        proj.deadline = null
        save(); closeModal(); rerenderProject()
      })
      return
    }
    // ── NOTES ──
    if (a === 'insert-link') {
      e.stopPropagation()
      const { noteId, projectId } = el.dataset
      const noteEl = document.querySelector(`[data-action="edit-note-content"][data-note-id="${noteId}"]`)
      const sel = savedSelection
      openModal(`
        <div class="p-5">
          <h2 class="text-base font-bold mb-1">Вставить ссылку</h2>
          <p class="text-xs text-white/40 mb-4">Выдели текст в заметке, затем вставь URL</p>
          <label class="block text-xs text-white/40 mb-1.5 font-medium uppercase tracking-wider">URL</label>
          <input id="link-url" type="url" placeholder="https://..."
            class="w-full bg-[#1d2125] border border-white/10 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500 mb-4"/>
          <button id="link-save"
            class="w-full bg-blue-600 hover:bg-blue-500 transition-colors rounded-lg py-2.5 text-sm font-semibold">
            Вставить
          </button>
        </div>`)
      setTimeout(() => document.getElementById('link-url')?.focus(), 40)
      const doInsert = () => {
        const url = document.getElementById('link-url').value.trim()
        if (!url || !/^https?:\/\//i.test(url)) {
          document.getElementById('link-url').style.borderColor = '#f87171'; return
        }
        closeModal()
        if (noteEl) {
          noteEl.focus()
          if (sel) restoreSelection(sel)
          document.execCommand('createLink', false, url)
          noteEl.querySelectorAll('a').forEach(a => {
            a.target = '_blank'; a.rel = 'noopener noreferrer'
          })
          const proj = getProject(projectId)
          const note = (proj.notes || []).find(n => n.id === noteId)
          if (note) { note.content = sanitizeNoteHTML(noteEl.innerHTML); saveProject() }
        }
      }
      document.getElementById('link-save').addEventListener('click', doInsert)
      document.getElementById('link-url').addEventListener('keydown', e2 => { if (e2.key === 'Enter') { e2.preventDefault(); doInsert() } })
      return
    }
    if (a === 'add-note') {
      const proj = getProject(el.dataset.projectId)
      if (!proj.notes) proj.notes = []
      proj.notes.push({ id: uid(), title: '📌 Заметка', content: '' })
      saveProject(); rerenderProject(); return
    }
    if (a === 'delete-note') {
      const proj = getProject(el.dataset.projectId)
      if (!confirm('Удалить заметку?')) return
      proj.notes = (proj.notes || []).filter(n => n.id !== el.dataset.noteId)
      saveProject(); rerenderProject(); return
    }
    if (a === 'edit-note-title') {
      const proj = getProject(el.dataset.projectId)
      const note = (proj.notes || []).find(n => n.id === el.dataset.noteId)
      const inp = document.createElement('input')
      inp.type = 'text'; inp.value = note.title
      inp.className = 'font-semibold text-sm flex-1 bg-[#1d2125] border border-blue-500 rounded px-2 py-0.5 focus:outline-none min-w-0 mr-2'
      el.replaceWith(inp); inp.focus(); inp.select()
      const done = () => { const v = inp.value.trim(); if (v) { note.title = v; saveProject() }; rerenderProject() }
      inp.addEventListener('blur', done)
      inp.addEventListener('keydown', e2 => { if (e2.key === 'Enter') { e2.preventDefault(); done() } if (e2.key === 'Escape') rerenderProject() })
      return
    }

    if (a === 'toggle-collapse') {
      const stId = el.dataset.subtaskId
      if (collapsed.has(stId)) collapsed.delete(stId)
      else collapsed.add(stId)
      rerenderProject(); return
    }
    if (a === 'show-add-subtask') {
      document.getElementById('add-subtask-form').classList.remove('hidden')
      el.classList.add('hidden')
      document.getElementById('new-subtask-title').focus(); return
    }
    if (a === 'cancel-add-subtask') {
      document.getElementById('add-subtask-form').classList.add('hidden')
      document.querySelector('[data-action="show-add-subtask"]').classList.remove('hidden'); return
    }
    if (a === 'confirm-add-subtask') {
      const inp = document.getElementById('new-subtask-title')
      const title = inp.value.trim()
      if (!title) { inp.focus(); return }
      const proj = getProject(currentProjectId)
      proj.subtasks.push({ id: uid(), title, tasks: [] })
      saveProject(); rerenderProject(); return
    }
    if (a === 'edit-subtask-title') {
      const proj = getProject(el.dataset.projectId)
      const st = proj.subtasks.find(s => s.id === el.dataset.subtaskId)
      const inp = document.createElement('input')
      inp.type = 'text'; inp.value = st.title
      inp.className = 'font-semibold text-sm flex-1 bg-[#1d2125] border border-blue-500 rounded px-2 py-0.5 focus:outline-none min-w-0 mr-2'
      el.replaceWith(inp); inp.focus(); inp.select()
      const done = () => { const v = inp.value.trim(); if (v) { st.title = v; saveProject() }; rerenderProject(); initDragDrop() }
      inp.addEventListener('blur', done)
      inp.addEventListener('keydown', e2 => { if (e2.key === 'Enter') { e2.preventDefault(); done() } if (e2.key === 'Escape') { rerenderProject(); initDragDrop() } })
      return
    }
    if (a === 'delete-subtask') {
      const proj = getProject(el.dataset.projectId)
      const st = proj.subtasks.find(s => s.id === el.dataset.subtaskId)
      if (st.tasks.length > 0 && !confirm(`Удалить подзадачу "${st.title}"?`)) return
      proj.subtasks = proj.subtasks.filter(s => s.id !== el.dataset.subtaskId)
      saveProject(); rerenderProject(); return
    }
    if (a === 'show-add-task') {
      const stId = el.dataset.subtaskId
      document.getElementById(`add-task-form-${stId}`).classList.remove('hidden')
      el.classList.add('hidden')
      document.getElementById(`new-task-input-${stId}`).focus(); return
    }
    if (a === 'cancel-add-task') {
      const stId = el.dataset.subtaskId
      document.getElementById(`add-task-form-${stId}`).classList.add('hidden')
      document.querySelector(`[data-action="show-add-task"][data-subtask-id="${stId}"]`).classList.remove('hidden'); return
    }
    if (a === 'confirm-add-task') {
      const { projectId, subtaskId } = el.dataset
      const inp = document.getElementById(`new-task-input-${subtaskId}`)
      const title = inp.value.trim()
      if (!title) { inp.focus(); return }
      const proj = getProject(projectId)
      const st = proj.subtasks.find(s => s.id === subtaskId)
      st.tasks.push({ id: uid(), title, done: false })
      saveProject(); rerenderProject(); return
    }
    if (a === 'edit-task-title') {
      const { projectId, subtaskId, taskId } = el.dataset
      const proj = getProject(projectId)
      const st = proj.subtasks.find(s => s.id === subtaskId)
      const task = st.tasks.find(t => t.id === taskId)
      const inp = document.createElement('input')
      inp.type = 'text'; inp.value = task.title
      inp.className = 'flex-1 text-sm bg-[#1d2125] border border-blue-500 rounded px-2 py-0.5 focus:outline-none'
      el.replaceWith(inp); inp.focus(); inp.select()
      const done = () => { const v = inp.value.trim(); if (v) { task.title = v; saveProject() }; rerenderProject(); initDragDrop() }
      inp.addEventListener('blur', done)
      inp.addEventListener('keydown', e2 => { if (e2.key === 'Enter') { e2.preventDefault(); done() } if (e2.key === 'Escape') { rerenderProject(); initDragDrop() } })
      return
    }
    if (a === 'delete-task') {
      const { projectId, subtaskId, taskId } = el.dataset
      const proj = getProject(projectId)
      const st = proj.subtasks.find(s => s.id === subtaskId)
      st.tasks = st.tasks.filter(t => t.id !== taskId)
      saveProject(); rerenderProject(); return
    }
  })

  document.addEventListener('input', e => {
    const ce = e.target.closest('[data-action="edit-note-content"]')
    if (!ce) return
    const { projectId, noteId } = ce.dataset
    const proj = getProject(projectId)
    const note = (proj.notes || []).find(n => n.id === noteId)
    if (note) { note.content = sanitizeNoteHTML(ce.innerHTML); saveProject() }
  })

  document.addEventListener('click', e => {
    const link = e.target.closest('.note-content a')
    if (link) { e.preventDefault(); window.open(link.href, '_blank', 'noopener,noreferrer') }
  }, true)

  document.addEventListener('paste', e => {
    const ce = e.target.closest('[data-action="edit-note-content"]')
    if (!ce) return
    e.preventDefault()
    const text = e.clipboardData.getData('text/plain')
    document.execCommand('insertText', false, text)
  })

  document.addEventListener('mousedown', e => {
    if (e.target.closest('[data-action="insert-link"]')) {
      savedSelection = saveSelection()
    }
  })

  document.addEventListener('change', e => {
    const inp = e.target.closest('[data-action="toggle-task"]')
    if (!inp) return
    const { projectId, subtaskId, taskId } = inp.dataset
    const proj = getProject(projectId)
    const st = proj.subtasks.find(s => s.id === subtaskId)
    const task = st.tasks.find(t => t.id === taskId)
    const wasDone = task.done
    task.done = inp.checked
    if (task.done && !wasDone) {
      const g = gam()
      const log = todayLog()
      g.coins += 1
      log.earned = (log.earned || 0) + 1
      log.tasks = (log.tasks || 0) + 1
      showCoinBurst(inp.closest('[data-drag-task]') || inp, 1)
      if (log.tasks === 3 && !log.q3) {
        log.q3 = true
        setTimeout(() => { g.coins += 25; log.earned += 25; save(); showQuestBanner('Закрыть 3 таска', 25); updateGamUI() }, 600)
      }
      if (log.tasks === 5 && !log.q5) {
        log.q5 = true
        setTimeout(() => { g.coins += 50; log.earned += 50; save(); showQuestBanner('Закрыть 5 тасков', 50); updateGamUI() }, 600)
      }
      save()
      updateGamUI()
    } else if (!task.done && wasDone) {
      const g = gam()
      const log = todayLog()
      g.coins = Math.max(0, g.coins - 1)
      log.earned = Math.max(0, (log.earned || 0) - 1)
      log.tasks = Math.max(0, (log.tasks || 0) - 1)
      save()
      updateGamUI()
    }
    saveProject(); rerenderProject()
  })

  document.getElementById('gam-overlay').addEventListener('click', closeGamPanel)
  document.getElementById('btn-home').addEventListener('click', () => go(''))
  document.getElementById('btn-new-project').addEventListener('click', showNewProjectModal)
  document.getElementById('btn-history').addEventListener('click', () => go('history'))
  document.getElementById('btn-backup').addEventListener('click', downloadBackup)
  document.getElementById('btn-stop-timer').addEventListener('click', async () => {
    await stopTimer()
    if (!currentProjectId && location.hash !== '#history') renderTodayActivity()
  })

  document.addEventListener('keydown', e => {
    if ((e.key === 'k' || e.key === 'K') && (e.ctrlKey || e.metaKey)) {
      const ce = e.target.closest('[data-action="edit-note-content"]')
      if (ce) {
        e.preventDefault()
        savedSelection = saveSelection()
        const noteId = ce.dataset.noteId
        document.querySelector(`[data-action="insert-link"][data-note-id="${noteId}"]`)?.click()
      }
    }
    if (e.key === 'Enter' && e.target.id === 'new-subtask-title') {
      document.querySelector('[data-action="confirm-add-subtask"]')?.click()
    }
    if (e.key === 'Enter' && e.target.id?.startsWith('new-task-input-')) {
      e.preventDefault()
      const stId = e.target.dataset.subtaskId
      document.querySelector(`[data-action="confirm-add-task"][data-subtask-id="${stId}"]`)?.click()
    }
    if (e.key === 'Escape') {
      if (!document.getElementById('modal-overlay').classList.contains('hidden')) closeModal()
    }
  })

  // ─── ELAPSED TICK ────────────────────────────────────────────────────────────
  setInterval(() => {
    if (currentProjectId) return
    for (const proj of projects()) {
      const el = document.getElementById(`elapsed-${proj.id}`)
      if (el) el.textContent = elapsedSince(proj.updatedAt)
    }
  }, 60000)

  // ─── LOGOUT ──────────────────────────────────────────────────────────────────
  document.getElementById('btn-logout').addEventListener('click', async () => {
    await sb.auth.signOut()
  })

  // ─── INIT ────────────────────────────────────────────────────────────────────
  ;(async () => {
    // Show loading state
    document.getElementById('app').innerHTML = `
      <div class="flex items-center justify-center min-h-[60vh]">
        <div class="text-white/30 text-sm">Загрузка...</div>
      </div>`

    // Reliable init: getSession first, then listen for changes
    const { data: { session } } = await sb.auth.getSession()

    if (session) {
      currentSession = session
      dataLoaded = true
      showHeaderAuth(session)
      await loadFromDB()
      restoreTimerFromData()
      updateGamUI()
      route()
      window.addEventListener('hashchange', () => { route(); if (currentProjectId) initDragDrop() })
    } else {
      renderAuth()
    }

    sb.auth.onAuthStateChange(async (event, session) => {
      currentSession = session
      if (event === 'SIGNED_IN' && session && !dataLoaded) {
        dataLoaded = true
        showHeaderAuth(session)
        await loadFromDB()
        restoreTimerFromData()
        updateGamUI()
        route()
        window.addEventListener('hashchange', () => { route(); if (currentProjectId) initDragDrop() })
      } else if (event === 'SIGNED_OUT') {
        if (activeTimer) { activeTimer = null; delete appData.activeTimer; clearInterval(timerInterval); timerInterval = null }
        dataLoaded = false
        currentSession = null
        currentProjectId = null
        appData = { projects: [] }
        renderAuth()
      }
    })
  })()
  </script>
</body>
</html>
